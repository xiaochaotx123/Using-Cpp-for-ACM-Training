https://codeforces.com/problemset/problem/33/B
string s1, s2;
int n, d[30][30];
void solve(){
    for(int i = 1; i <= 26; i ++){
        for(int j = 1; j <= 26; j ++) d[i][j] = 10000000;
    }
    for(int i = 1; i <= 26; i ++) d[i][i] = 0;
    cin >> s1 >> s2;
    cin >> n;

    for(int i = 1; i <= n; i ++){
        char a, b; cin >> a >> b;
        int u = a - 'a' + 1, v = b - 'a' + 1;
        int x; cin >> x;
        d[u][v] = min(d[u][v], x);
    }
    
    if((int)s1.size() != (int)s2.size()){
        cout << -1 << endl;
        return ;
    }
    for(int k = 1; k <= 26; k ++){
        for(int i = 1; i <= 26; i ++){
            for(int j = 1; j <= 26; j ++){
                d[i][j] = min(d[i][j], d[i][k] + d[k][j]);
            }
        }
    }

    string fans = "";
    int fcost = 0;
    for(int i = 0; i < (int)s1.size(); i ++){
        int u = s1[i] - 'a' + 1, v = s2[i] - 'a' + 1;
        int min_cost = d[u][v], ans = v;
        for(int j = 1; j <= 26; j ++){
            if(d[u][j] + d[v][j] < min_cost){
                min_cost = d[u][j] + d[v][j];
                ans = j;
            }
        }
        char now_ans = (ans - 1) + 'a';
        fans += now_ans;
        fcost += min_cost;
    }
    if(fcost >= 10000000){
        cout << "-1" << endl;
        return ;
    }
    cout << fcost << endl;
    cout << fans << endl;
    return ;
}

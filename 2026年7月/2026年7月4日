const int N = 400000 + 100;
int n, m;
string a[N];
map<string, int> ma;
map<int, string> rma;
int idx;

vector<int> adj[N];

int dfn[N], low[N], dfn_cnt;
int scc_id[N], scc_cnt;
bool in_stack[N];
stack<int> st;

int scc_r[N], scc_len[N];
int word_r[N], word_len[N];

vector<int> dag[N];
int dp_r[N], dp_len[N];


void tarjan(int u){
    dfn[u] = low[u] = ++ dfn_cnt;
    st.push(u);
    in_stack[u] = true;

    for(int v : adj[u]){
        if(!dfn[v]){
            tarjan(v);
            low[u] = min(low[u], low[v]);
        }
        else if(in_stack[v]){
            low[u] = min(low[u], dfn[v]);
        }
    }
    if(dfn[u] == low[u]){
        scc_cnt ++;
        scc_r[scc_cnt] = 1000000000;
        scc_len[scc_cnt] = 1000000000;
        int v = 0;
        while(v != u){
            v = st.top();
            st.pop();
            in_stack[v] = false;
            scc_id[v] = scc_cnt;
            if(word_r[v] < scc_r[scc_cnt] || 
                (word_r[v] == scc_r[scc_cnt] && word_len[v] < scc_len[scc_cnt])){
                    scc_r[scc_cnt] = word_r[v];
                    scc_len[scc_cnt] = word_len[v];
            }
        }
    }
}

void dfs_dag(int u){
    if(dp_r[u] != -1) return ;
    dp_r[u] = scc_r[u];
    dp_len[u] = scc_len[u];
    for(int v : dag[u]){
        dfs_dag(v);
        if(dp_r[v] < dp_r[u] || 
            (dp_r[v] == dp_r[u] && dp_len[v] < dp_len[u])){
                dp_r[u] = dp_r[v];
                dp_len[u] = dp_len[v];
        }
    }
}

int add_word(const string &s){
    if(ma.count(s) == 0){
        ma[s] = ++ idx;
        rma[idx] = s;
        int cnt_r = 0;
        for(char c : s) if(c == 'r') cnt_r ++;
        word_r[idx] = cnt_r;
        word_len[idx] = (int)s.size();
    }
    return ma[s];
}

string to_lower(const string &s){
    string t = s;
    for(int i = 0; i < (int)t.size(); i ++){
        if('A' <= t[i] && t[i] <= 'Z') t[i] = (char)(t[i] - 'A' + 'a');
    }
    return t;
}

void solve(){
    
    cin >> n;
    for(int i = 1; i <= n; i ++){
        string s; cin >> s;
        a[i] = to_lower(s);
        add_word(a[i]);
    }

    cin >> m;
    for(int i = 1; i <= m; i ++){
        string s1, s2; cin >> s1 >> s2;
        s1 = to_lower(s1);
        s2 = to_lower(s2);
        int u = add_word(s1);
        int v = add_word(s2);
        adj[u].push_back(v);
    }

    for(int i = 1; i <= idx; i ++){
        if(!dfn[i]) tarjan(i);
    }
    
    for(int u = 1; u <= idx; u ++){
        for(int v : adj[u]){
            if(scc_id[u] != scc_id[v]){
                dag[scc_id[u]].push_back(scc_id[v]);
            }
        }
    }

    memset(dp_r, -1, sizeof(dp_r));

    for(int i = 1; i <= scc_cnt; i ++) dfs_dag(i);

    int ansr = 0, anslen = 0;
    for(int i = 1; i <= n; i ++){
        int u = ma[a[i]];
        int sid = scc_id[u];
        ansr += dp_r[sid];
        anslen += dp_len[sid];
    }
    cout << ansr << " " << anslen << endl;
    return ;
}

const int N = 2000 + 100;
vector<int> adj[N];
int vis[N];

int n, a[N], max_len = 1;

void dfs(int u, int depth){
    max_len = max(max_len, depth);
    for(int v : adj[u]){
        dfs(v, depth + 1);
    }
}

void solve(){
    
    cin >> n;
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        if(a[i] != -1) adj[a[i]].push_back(i);
    }
    for(int i = 1; i <= n; i ++){
        if(a[i] == -1) dfs(i, 1);
    }
    cout << max_len << endl;
    return ;
}

const int N = 300 + 100;
int n, p[N];
int find(int x){
    if(x != p[x]) p[x] = find(p[x]);
    return p[x];
}

void solve(){
    
    cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        p[i] = i;
    }
    for(int i = 1; i <= n; i ++){
        for(int j = 1; j <= n; j ++){
            char sh; cin >> sh;
            if(i < j && sh == '1'){
                int u = a[i], v = a[j];
                int fu = find(u), fv = find(v);
                if(fu != fv) p[fu] = fv;
            }
        }
    }
    vector<int> vis(n + 10);
    for(int i = 1; i <= n; i ++){
        int min_num = n + 10;
        for(int j = 1; j <= n; j ++){
            if(vis[a[j]]) continue;
            int u = a[i], v = a[j];
            int fu = find(u), fv = find(v);
            if(fu == fv && min_num > a[j]){
                min_num = a[j];
            }
        }
        vis[min_num] = 1;
        cout << min_num << " ";
    }
    cout << endl;
    return ;
}

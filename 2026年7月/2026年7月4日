const int N = 100000 + 100;
int n, m;

int p[N], money[N];
int find(int x){
    if(x != p[x]) p[x] = find(p[x]);
    return p[x];
}

void solve(){
    
    cin >> n >> m;
    for(int i = 1; i <= n; i ++){
        p[i] = i;
        cin >> money[i];
    }
    for(int i = 1; i <= m; i ++){
        int u, v; cin >> u >> v;
        int fu = find(u), fv = find(v);
        if(fu != fv){
            money[fv] = min(money[fv], money[fu]);
            p[fu] = fv;
        }
    }
    int ans = 0;
    for(int i = 1; i <= n; i ++){
        if(i == p[i]) ans += money[i];
    }
    cout << ans << endl;
    return ;
}

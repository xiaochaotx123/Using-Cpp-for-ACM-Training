const int N = 100000 + 100;

set<string> se;
map<string, int> ma;
map<int, string> rma;
map<int, int> nex;

int find(int x){
    if(nex[x] == -1) return x;
    else{
        nex[x] = find(nex[x]);
        return nex[x];
    }
}
void solve(){
    
    int n; cin >> n;
    vector<pair<string, string> > a(n + 10);
    for(int i = 1; i <= n; i ++){
        string s1, s2; cin >> s1 >> s2;
        se.insert(s1);
        se.insert(s2);
        a[i].first = s1;
        a[i].second = s2;
    }
    int idx = 0;
    for(string s : se) ma[s] = ++ idx, rma[idx] = s;
    for(int i = 1; i <= idx; i ++) nex[i] = -1;
    for(int i = 1; i <= n; i ++){
        string s1 = a[i].first, s2 = a[i].second;
        nex[ma[s1]] = ma[s2];
    }
    int q; cin >> q;
    string s;
    cin.ignore();
    while(q --){
        getline(cin, s);
        string now_s = "";
        for(int i = 0; i < (int)s.size(); i ++){
            if(s[i] == ' '){
                if(ma.count(now_s) == 0) cout << now_s;
                else{
                    int num = find(ma[now_s]);
                    cout << rma[num];
                }
                cout << " ";
                now_s = "";
            }
            else now_s += s[i];
        }
        if(ma.count(now_s) == 0) cout << now_s;
        else{
            int num = find(ma[now_s]);
            cout << rma[num];
        }        
        cout << endl;
    }
    return ;
}

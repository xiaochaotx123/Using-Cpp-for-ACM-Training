int gcd(int a, int b){
    if(!b) return a;
    else return gcd(b, a % b);
}

void solve(){
    
    int n; cin >> n;
    int a = 1, b = n;
    for(int i = 2; i * i <= n; i ++){
        if(n % i == 0){
            if(gcd(i, n / i) != 1) continue; 
            int max_num = max(i, n / i);
            if(max_num < max(a, b)) a = i, b = n / i;
        }
    }
    cout << a << " " << b << endl;
    return ;
}

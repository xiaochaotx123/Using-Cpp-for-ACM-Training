void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10), pre(n + 10), suf(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int max_num = 0;
    for(int i = n; i >= 1; i --){
        if(i <= n - 1) suf[i] = max_num;
        max_num = max(max_num, a[i] + i - 1);
    }
    max_num = 0;
    for(int i = 1; i <= n; i ++){
        if(i >= 2) pre[i] = max_num;
        max_num = max(max_num, a[i] + n - i);
    }
    int ans = 1000000000000000000;
    for(int i = 1; i <= n; i ++){
        int now_ans = max({a[i], pre[i], suf[i]});
        ans = min(ans, now_ans);
    }
    cout << ans << endl;
    return ;
}

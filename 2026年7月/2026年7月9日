void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int cnt1 = 0, cnt2 = 0, cnt3 = 0;
    for(int i = 1; i <= n; i ++){
        if(i >= 2 && cnt1 >= cnt2 + cnt3 && i <= n - 1){
            if(a[i] != 3){
                cout << "YES" << endl;
                return ;
            }
            if(cnt1 == cnt2 + cnt3){
                cnt1 = 0, cnt2 = 0, cnt3 = 0;
                for(int j = i; j <= n - 1; j ++){
                    if(a[j] == 1) cnt1 ++;
                    else if(a[j] == 2) cnt2 ++;
                    else cnt3 ++;
                    if(cnt1 + cnt2 >= cnt3){
                        cout << "YES" << endl;
                        return ;
                    }
                } 
                cout << "NO" << endl;
                return ;
            }
        }

        if(a[i] == 1) cnt1 ++;
        else if(a[i] == 2) cnt2 ++;
        else cnt3 ++;
    }
    cout << "NO" << endl;
    return ;
}

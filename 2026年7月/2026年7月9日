但是有一个容易遗漏的问题就是i - a[i]可能为负数, i - a[i]的范围为[1 - n, n - 1], 所以我们直接加上n, 此时范围变为[1, 2 * n - 1]
修改为: 
vector<int> max_idx(2 * n + 10)
for(int i = 1; i <= n; i ++){
    int x = i - a[i] + n;
    max_idx[x] = max(max_idx[x], i);
}
for(int i = 2 * n; i >= 1; i --){
    max_idx[i] = max(max_idx[i], max_idx[i + 1]);
}
所以现在得到了对于每一个左端点j满足k - a[k] >= j的最远的k = max_idx[j]

所以直接判断k - a[k] >= j是否成立即可
如果成立那么区间[j + 1, k - 1]中的所以的i均不可能成为起点

for(int j = 1; j <= n; j ++){
    int pos = max_idx[j + n]; // 因为在一开始初始化max_idx[]时都加上了n, 所以这里也要加上n
    if(pos >= j + a[j]){
        dif[j + 1] ++;
        dif[pos] --;
    }
}

void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    vector<int> dif(n + 10), max_idx(2 * n + 10);
    for(int i = 1; i <= n; i ++){
        if(i - a[i] >= 1){
            dif[1] ++;
            dif[i - a[i] + 1] --;
        }
        if(i + a[i] <= n){
            dif[i + a[i]] ++;
            dif[n + 1] --;
        }
    }

    for(int i = 1; i <= n; i ++){
        int x = i - a[i] + n;
        max_idx[x] = max(max_idx[x], i);
    }
    for(int i = 2 * n; i >= 1; i --){
        max_idx[i] = max(max_idx[i], max_idx[i + 1]);
    }

    for(int j = 1; j <= n; j ++){
        int pos = max_idx[j + n];
        if(pos >= j + a[j]){
            dif[j + 1] ++;
            dif[pos] --;
        }
    }
    for(int i = 1; i <= n; i ++) dif[i] += dif[i - 1];
    int ans = 0;
    for(int i = 1; i <= n; i ++){
        if(!dif[i]) ans ++;
    }
    cout << ans << endl;
    return ;
}

const int mod = 998244353;

int ksm(int a, int b, int p){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a) % p;
        b >>= 1;
        a = (a * a) % p;
    }
    return sum;
}

void solve(){
    
    int n; cin >> n;
    vector<int> ans(n + 10);
    ans[1] = 10, ans[2] = 180;
    int pre = ans[1] + ans[2];
    for(int i = 3; i <= n; i ++){
        ans[i] = (i * ksm(10, i, mod) - (i - 1) * ksm(10, i - 1, mod) - pre + mod) % mod;
        pre = (pre + ans[i] + mod) % mod;
    }
    for(int i = n; i >= 1; i --) cout << (ans[i] + mod) % mod << " ";
    cout << endl;

    return ;
}

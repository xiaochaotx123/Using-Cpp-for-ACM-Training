void solve(){
    
    int n, m; cin >> n >> m;
    string s; cin >> s;
    string op; cin >> op;
    for(char x : op){
        if(x == '+'){
            s.back() += 1;
            int pos = (int)s.size() - 1;
            while(s[pos] == '2'){
                s[pos] = '0';
                s[pos - 1] += 1;
                pos --;
            }
        }
        else if(x == '-'){
            int pos = (int)s.size() - 1;
            while(s[pos] == '0'){
                s[pos] = '1';
                pos --;
            }
            s[pos] = '0';
        } 
        else if(x == '*') s += "0";
        else if(x == '/') s.pop_back();
    }
    cout << s << endl;
    return ;
}

const int N = 20;
const int mod = 99999989;

int n;
char a[N];
map<char, int> ma;

int ksm(int a, int b, int p){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a) % p;
        b >>= 1;
        a = (a * a) % p;
    }
    return sum;
}

int get_num(){
    int ans = 0;

    for(int i = 1; i <= n; i ++){
        int high = 0;
        for(int j = 1; j < i; j ++) high = high * 16 + ma[a[j]];
        int now = ma[a[i]];
        int low = 0;
        for(int j = i + 1; j <= n; j ++) low = low * 16 + ma[a[j]];
        int factor = ksm(16, n - (i + 1) + 1, mod);
        
        if(now > 2) ans = (ans +  (high + 1) * factor) % mod;
        else if(now == 2) ans = (ans + high * factor + low + 1) % mod;
        else ans = (ans + high * factor) % mod;
    }

    return ans;
}
void solve(){
    
    for(int i = '0'; i <= '9'; i ++) ma[i] = i - '0';
    for(int i = 'A'; i <= 'F'; i ++) ma[i] = i - 'A' + 10;

    cin >> n;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    cout << get_num() << endl;
    return ;
}

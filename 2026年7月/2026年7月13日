int n;

int work(int x){
    int sum = 0;
    int m = n;
    while(m){
        sum += (m % x);
        m /= x;
    }
    return sum;
}

int gcd(int a, int b){
    if(!b) return a;
    else return gcd(b, a % b);
}
void solve(){
    
    cin >> n;
    int fz = 0, fm = n - 2;
    for(int i = 2; i <= n - 1; i ++){
        fz += work(i);
    }
    int g = gcd(fz, fm);
    cout << fz / g << "/" << fm / g << endl;
    return ;
}

int get_len(int x){
    int len = 0;
    while(x){
        len ++;
        x /= 10;
    }
    return len;
}

void solve(){
    
    int n; cin >> n;
    for(int i = 1; ;i ++){
        int now_len = get_len(i);
        if(n - now_len > 0) n -= now_len;
        else{
            vector<int> v;
            int x = i;
            while(x){
                v.push_back(x % 10);
                x /= 10;
            }
            reverse(v.begin(), v.end());
            cout << v[n - 1] << endl;
            return ;
        }
    }
    return ;
}

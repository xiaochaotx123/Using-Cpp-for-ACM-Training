bool cmp(pair<int, int> a, pair<int, int> b){
    return a.second > b.second;
}

void solve(){
    
    int n; cin >> n;
    vector<char> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int ans = 0;
    vector<pair<int, int> > b(n + 10);
    for(int i = 1; i <= n; i ++){
        if(a[i] == 'L'){
            ans += i - 1;
            // 5 - 3 = 2
            // n - i - (i - 1) = n - i - i + 1
            b[i] = {i - 1, n - i - i + 1};
        }
        else{
            ans += n - i;
            // i - 1 - n + i
            b[i] = {n - i, i - 1 - n + i};
        }
    }
    sort(b.begin() + 1, b.begin() + 1 + n, cmp);
    int other_ans = 0;
    for(int i = 1; i <= n; i ++){
        if(b[i].second > 0) other_ans += b[i].second;
        cout << ans + other_ans << " ";
    }
    cout << endl;
    return ;
}

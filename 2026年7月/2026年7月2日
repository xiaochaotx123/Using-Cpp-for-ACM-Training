https://www.matiji.net/exam/brushquestion/175/3181/1DC60EA6DF83A333301CFFE1407FBA59
1，如果d[i][j] = -1，标识i字符顺序小于j字符；如果等他1，表示大于；如果等于0，表示没有关系
2，A[]和B[]表示对于u < j时 A[]比u小，B[]中比j大，
   这样需要考虑三个顺序，第一个顺序时 u比（比j大的字符）小，（比u小的字符）比j小，（比u小的字符）比（比j大的字符）小
   因为关系是相互联系的，不能之间里u和j的关系

const int N = 300000 + 100;

int p, trie[N][30];
int cnt[N], idx;
int d[30][30];
int A[N], B[N];

void insert(string s){
    int p = 0;
    for(int i = 0; i < (int)s.size(); i ++){
        int u = s[i] - 'a';
        if(!trie[p][u]) trie[p][u] = ++ idx;
        p = trie[p][u];
    }
    cnt[p] ++;
}

bool check(string s){
    memset(d, 0, sizeof(d)); // 每次判断一个字符串是否存在某种顺序使得字典序最小，都要将各个字符之间关系重置
    int p = 0;
    for(int i = 0; i < (int)s.size(); i ++){
        int u = s[i] - 'a';
        if(cnt[p]) return false;
        
        for(int j = 0; j < 26; j ++){
            // 如果这个字符和u在字典树中是同一横排的，那么u要比所有同横排的字符都要是 小的关系
            if(trie[p][j] && j != u && d[u][j] == 1) return false; 
        }
        A[0] = B[0] = 0; // 因为A[0]和B[0]没用，故可以当作下标
        for(int j = 0; j < 26; j ++){
            if(trie[p][j] && j != u){ // 因为之前已经怕判断过了，所以u和j的关系一定是u比j小，j比u大
                d[u][j] = -1;
                d[j][u] = 1;
                for(int k = 0; k < 26; k ++){
                    if(d[j][k] == -1){ // 如果k比j大，那么新建关系u比k小，k比u大
                        d[u][k] = -1;
                        d[k][u] = 1;
                        B[++ B[0]] = k; 
                    }
                    if(d[k][u] == -1){ // 如果k比u小，那么新建关系k比j小，j比k大
                        d[k][j] = -1;
                        d[j][k] = 1;
                        A[++ A[0]] = k;
                    }
                }
            }
        }

        // 这个就是新建 （所有比u小的字符）比（所有比j大的字符）小，（所有比j大的字符）比（所有比u小的字符）大
        for(int j = 1; j <= A[0]; j ++){
            for(int k = 1; k <= B[0]; k ++){
                d[A[j]][B[k]] = -1;
                d[B[k]][A[j]] = 1;
            }
        }

        p = trie[p][u]; // 遍历字符串的下一个字符
    }
    return true;
}
void solve(){
    
    int n; cin >> n;
    vector<string> s(n + 10), ans;
    for(int i = 1; i <= n; i ++){
        cin >> s[i];
        insert(s[i]);
    }
    for(int i = 1; i <= n; i ++){
        if(check(s[i])) ans.push_back(s[i]);
    }
    cout << (int)ans.size() << endl;
    for(string e : ans) cout << e << endl;
    return ;
}

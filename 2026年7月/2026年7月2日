https://codeforces.com/contest/1490/problem/G
const int N = 200000 + 100;

int n, m, a[N], x[N], pre[N], pre_idx[N];
int fpre[N];

bool check(int x, int cnt, int max_num){
    x -= cnt * pre[n];
    if(max_num >= x) return true;
    else return false;
}
int work(int x){
    
    if(fpre[n] >= x){
        int l = 1, r = n, ans_pos = n;
        while(l <= r){
            int mid = (l + r) / 2;
            if(fpre[mid] >= x){
                ans_pos = mid;
                r = mid - 1;
            }
            else l = mid + 1;
        }
        return ans_pos - 1;
    }

    if(pre[n] <= 0) return -1;
    int max_num = pre[pre_idx[n]];
    
    int l = 1, r = x / pre[n] + 10, pos = 1;
    while(l <= r){
        int mid = (l + r) / 2;
        if(check(x, mid, max_num)){
            pos = mid;
            r = mid - 1;
        }
        else l = mid + 1;
    }
    
    int ans = pos * n - 1;
    // cout << "ans == " << ans << endl;
    // cout << "pos == " << pos << endl;
    x -= pos * pre[n];
    
    // cout << "x == " << x << endl;
    l = 1, r = n;
    int pos1 = 1;
    while(l <= r){
        int mid = (l + r) / 2;
        if(fpre[mid] >= x){
            pos1 = mid;
            r = mid - 1;
        }
        else l = mid + 1;
    }
    // cout << "pos1 == " << pos1 << endl;
    return ans + pos1;
}
void solve(){
    
    cin >> n >> m;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    for(int i = 1; i <= m; i ++) cin >> x[i];
    for(int i = 1; i <= n; i ++) pre[i] = pre[i - 1] + a[i];
    pre_idx[1] = 1;
    fpre[1] = pre[1];
    for(int i = 2; i <= n; i ++){
        if(pre[i] > pre[pre_idx[i - 1]]) pre_idx[i] = i;
        else pre_idx[i] = pre_idx[i - 1];
        fpre[i] = max(fpre[i - 1], pre[i]);
    }

    // for(int i = 1; i <= n; i ++) cout << pre[i] << " ";
    // cout << endl;
    // for(int i = 1; i <= n; i ++) cout << pre_idx[i] << " ";
    // cout << endl;

    vector<int> ans(m + 10);
    for(int i = 1; i <= m; i ++) ans[i] = work(x[i]);
    for(int i = 1; i <= m; i ++) cout << ans[i] << " ";
    cout << endl;
    return ;
}

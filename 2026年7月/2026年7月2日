void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    sort(a.begin() + 1, a.begin() + 1 + n);
    map<int, int> ma;
    for(int i = 1; i <= n; i ++) ma[a[i]] ++;
    vector<int> cnt(n + 10);
    int idx = 0;
    for(auto [x, y] : ma) cnt[++ idx] = y;
    sort(cnt.begin() + 1, cnt.begin() + 1 + idx);
    vector<int> pre(idx + 10);
    for(int i = 1; i <= idx; i ++) pre[i] = pre[i - 1] + cnt[i];
    int ans = n;
    for(int i = 1; i <= idx; i ++){
        int now_ans = pre[i - 1] + (pre[idx] - pre[i]) - (idx - i) * cnt[i];
        ans = min(ans, now_ans);
    }
    cout << ans << endl;
    return ;
}

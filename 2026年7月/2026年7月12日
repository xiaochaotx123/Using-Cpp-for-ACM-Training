int needb, needs, needc;
int nb, ns, nc;
int pb, ps, pc;
int money;

bool check(int x){
    int now_needb = x * needb - nb;
    int now_needs = x * needs - ns;
    int now_needc = x * needc - nc;
    int now_need_money = 0;
    if(now_needb > 0) now_need_money += now_needb * pb;
    if(now_needs > 0) now_need_money += now_needs * ps;
    if(now_needc > 0) now_need_money += now_needc * pc;
    if(now_need_money <= money) return true;
    else return false;
}
void solve(){
    
    string s; cin >> s;
    for(char e : s){
        if(e == 'B') needb ++;
        else if(e == 'S') needs ++;
        else needc ++;
    }    
    cin >> nb >> ns >> nc;
    cin >> pb >> ps >> pc;
    cin >> money;

    int l = 0, r = 1000000000000000, ans_num = 0;
    while(l <= r){
        int mid = (l + r) / 2;
        if(check(mid)){
            ans_num = mid;
            l = mid + 1;
        }
        else r = mid - 1;
    }
    cout << ans_num << endl;
    return ;
}

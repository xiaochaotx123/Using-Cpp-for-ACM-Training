void solve(){
    
    int n; cin >> n;
    int total_num = 0;
    vector<int> a(n + 10), pre(n + 10), suf(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i], total_num += a[i];
    if(total_num % 3){
        cout << 0 << endl;
        return ;
    }
    total_num /= 3;
    for(int i = 1; i <= n; i ++) pre[i] = pre[i - 1] + a[i];
    for(int i = n; i >= 1; i --) suf[i] = suf[i + 1] + a[i];

    vector<int> pos1, pos2;
    for(int i = 1; i <= n; i ++){
        if(pre[i] == total_num) pos1.push_back(i);
    }
    for(int i = n; i >= 1; i --){
        if(suf[i] == total_num) pos2.push_back(i);
    }
    reverse(pos2.begin(), pos2.end());

    int ans = 0;
    for(int x : pos1){
        int l = 0, r = (int)pos2.size() - 1, pos = -1;
        while(l <= r){
            int mid = (l + r) / 2;
            if(pos2[mid] > x + 1){
                pos = mid;
                r = mid - 1;
            }
            else l = mid + 1;
        }
        if(pos != -1) ans += (int)pos2.size() - pos;
    }
    cout << ans << endl;
    return ;
}

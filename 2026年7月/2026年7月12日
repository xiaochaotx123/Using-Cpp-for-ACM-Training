https://codeforces.com/problemset/problem/1783/C
bool cmp(pair<int, int> a, pair<int, int> b){
    return a.first < b.first;
}
bool cmp1(pair<int, int> a, pair<int, int> b){
    return a.second < b.second;
}

void solve(){
    
    int n, m; cin >> n >> m;
    vector<pair<int, int> > a(n + 10);
    vector<int> vis(n + 10);
    for(int i = 1; i <= n; i ++){
        cin >> a[i].first;
        a[i].second = i - 1;
    }
    sort(a.begin() + 1, a.begin() + 1 + n, cmp);
    int ans = 0;
    for(int i = 1; i <= n; i ++){
        if(m - a[i].first >= 0){
            m -= a[i].first;
            vis[a[i].second] = 1;
            ans ++;
        }
    }

    if(vis[ans]){
        int fans = 1;
        for(int i = 1; i <= n; i ++){
            if(a[i].second > ans) fans ++;
        }
        cout << fans << endl;
        return ;
    }
    sort(a.begin() + 1, a.begin() + 1 + n, cmp1);
    int max_num = 0;
    for(int i = 1; i <= n; i ++){
        if(vis[a[i].second]) max_num = max(max_num, a[i].first);
    }

    m += max_num;
    int total_cost = 0;
    for(int i = 1; i <= n; i ++){
        if(a[i].second == ans) total_cost += a[i].first;
    }
    // cout << ans << " " << m << " " << total_cost << endl;
    int fans = 1;
    for(int i = 1; i <= n; i ++){
        if(a[i].second > ans) fans ++;
    }
    if(m >= total_cost) cout << fans << endl;
    else cout << fans + 1 << endl;
    return ;
}

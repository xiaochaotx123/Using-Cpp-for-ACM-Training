void solve(){
    
    int n, k; cin >> n >> k;
    vector<int> a(n + 10), pre(n + 10);
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        pre[i] = pre[i - 1] + a[i];
    }
    double ans = 0.0;
    for(int i = 1; i <= n; i ++){
        for(int j = i + k - 1; j <= n; j ++){
            int sum = pre[j] - pre[i - 1];
            double now_ans = sum * 1.0 / (j - i + 1);
            ans = max(ans, now_ans);
        }
    }
    cout << fixed << setprecision(15) << ans << endl;
    return ;
}

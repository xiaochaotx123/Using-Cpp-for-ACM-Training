    for(int i = 1; i <= 2000000; i ++){
        a[i] += a[i - 1];
        if(a[i] >= k) pos.push_back(i);
    }
    while(q --){
        int left, right; cin >> left >> right;
        int l = 0, r = (int)pos.size() - 1, posl = -1;
        while(l <= r){
            int mid = (l + r) / 2;
            if(pos[mid] >= left){
                posl = mid;
                r = mid - 1;
            }
            else l = mid + 1;
        }
        if(posl == -1){
            cout << 0 << endl;
            continue;

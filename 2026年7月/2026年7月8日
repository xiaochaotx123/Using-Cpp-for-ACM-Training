int gcd(int a, int b){
    if(!b) return a;
    else return gcd(b, a % b);
}
void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10), b(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    for(int i = 1; i <= n; i ++) cin >> b[i];

    for(int i = n; i >= 1; i --){
        if(a[i] || b[i]){
            if(!a[i]) cout << 0 << "/" << 1 << endl;
            else if(!b[i]) cout << 1 << "/" << 0 << endl;
            else{
                int g = gcd(a[i], b[i]);
                cout << a[i] / g << "/" << b[i] / g << endl;
            }
            return ;
        }
    }
    return ;
}

void solve(){
    
    int n; cin >> n;
    map<string, int> ma;
    vector<string> a(n + 10);
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        ma[a[i]] ++;
    }
    int min_num = n + 10;
    for(auto [_, cnt] : ma) min_num = min(min_num, cnt);
    for(int i = 1; i <= n; i ++){

void solve(){
    
    int n; cin >> n;
    int sum_digit = 0;
    int m = n;
    while(m){
        sum_digit += (m % 10);
        m /= 10;
    }

    vector<int> ans;
    for(int i = 1; i * i <= n; i ++){
        if(n % i == 0){
            if(sum_digit % i == 0) ans.push_back(i);

            if(i * i != n){
                if(sum_digit % (n / i) == 0) ans.push_back(n / i);
            }
        }
    }
    sort(ans.begin(), ans.end());
    cout << (int)ans.size() << endl;
    for(int e : ans) cout << e << " ";
    cout << endl;
    return ;
}

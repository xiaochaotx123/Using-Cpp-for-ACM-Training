const int mod = 998244353;

int ksm(int a, int b, int p){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a) % p;
        a = (a * a) % p;
        b >>= 1;
    }
    return sum;
}

void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    
    map<int, int> nex;
    for(int i = n; i >= 1; i --){
        if(nex.count(a[i]) == 0) nex[a[i]] = i;
    }
    int len = 0, nex_r = nex[a[1]], idx = 1;
    while(idx <= n){

        while(idx <= nex_r){
            nex_r = max(nex_r, nex[a[idx]]);
            idx ++;
        }
        nex_r = nex[a[idx]];
        len ++;
    }
    cout << ksm(2, len - 1, mod) << endl;
    return ;
}

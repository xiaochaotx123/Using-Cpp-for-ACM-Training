https://codeforces.com/problemset/problem/2176/C
bool cmp(int a, int b){
    return a > b;
}

void solve(){
    
    int n; cin >> n;
    vector<int> v1(n + 10), v2(n + 10);
    int idx1 = 0, idx2 = 0;
    for(int i = 1; i <= n; i ++){
        int x; cin >> x;
        if(x & 1) v1[++ idx1] = x;
        else v2[++ idx2] = x;
    }
    sort(v1.begin() + 1, v1.begin() + 1 + idx1, cmp);
    sort(v2.begin() + 1, v2.begin() + 1 + idx2, cmp);
    vector<int> pre1(idx1 + 10), pre2(idx2 + 10);
    for(int i = 1; i <= idx1; i ++) pre1[i] = pre1[i - 1] + v1[i];
    for(int i = 1; i <= idx2; i ++) pre2[i] = pre2[i - 1] + v2[i];
    
    for(int i = 1; i <= n; i ++){
        if(i & 1){
            // 奇数为奇数个，偶数为偶数个
            if(idx1 == 0) cout << 0 << " ";
            else{
                if(idx2 == 0) cout << pre1[1] << " ";
                else{
                    if(idx2 & 1){
                        int max_idx2 = min(i - 1, idx2 - 1);
                        if(idx1 >= i - max_idx2) cout << pre1[1] + pre2[max_idx2] << " ";
                        else cout << 0 << " ";
                    }
                    else cout << pre1[1] + pre2[min(i - 1, idx2)] << " ";
                }

            }
        }
        else{
            // 奇数为奇数个，偶数为奇数个
            if(idx1 == 0) cout << 0 << " ";
            else{
                if(idx2 == 0) cout << 0 << " ";
                else{
                    if(idx2 & 1) cout << pre1[1] + pre2[min(i - 1, idx2)] << " ";
                    else{
                        int max_idx2 = min(i- 1, idx2 - 1);
                        if(idx1 >= i - max_idx2) cout << pre1[1] + pre2[max_idx2] << " ";
                        else cout << 0 << " ";
                    }
                }
            }
        }
    }
    cout << endl;
    return ;
}

void solve(){
    
    int n, k; cin >> n >> k;
    vector<int> a(n + 10), pos(n + 10);
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        pos[a[i]] = i;
    }
    vector<int> pre(n + 10), nex(n + 10);
    for(int i = 1; i <= n; i ++){
        pre[i] = i - 1;
        nex[i] = i + 1;
    }
    vector<int> ans(n + 10);
    int team = 1;
    for(int i = n; i >= 1; i --){
        int idx = pos[i];
        if(ans[idx] != 0) continue;

        ans[idx] = team;
        int left = pre[idx];
        for(int j = 1; j <= k && left != 0; j ++){
            ans[left] = team;
            left = pre[left];
        }
        int right = nex[idx];
        for(int j = 1; j <= k && right != n + 1; j ++){
            ans[right] = team;
            right = nex[right];
        }

        if(left != 0) nex[left] = right;
        if(right != n + 1) pre[right] = left;

        team = 3 - team;
    }
    for(int i = 1; i <= n; i ++) cout << ans[i];
    cout << endl;
    return ;
}

int n, k;

bool cmp(pair<int, pair<int, int> > a, pair<int, pair<int, int> > b){
    return a.second.first < b.second.first;
}

struct cmp1{
    bool operator()(const pair<int, int> &a, const pair<int, int> &b) const{
        return a.first > b.first;
    }
};

void solve(){
    
    cin >> n >> k;
    vector<pair<int, pair<int, int> > > a(n + 10);
    for(int i = 1; i <= n; i ++){
        a[i].first = i;
        cin >> a[i].second.first >> a[i].second.second;
    }
    sort(a.begin() + 1, a.begin() + 1 + n, cmp);

    priority_queue<pair<int, int>, vector<pair<int, int> >, cmp1> q;
    vector<int> vis(n + 10);
    int max_len = 0;
    for(int i = 1; i <= n; i ++){
        if((int)q.size() < k){
            q.push({a[i].second.second, a[i].first});
        }
        else{
            if(a[i].second.second > q.top().first){
                q.pop();
                q.push({a[i].second.second, a[i].first});              
            }
        }

        if((int)q.size() == k){
            int now_r = q.top().first;
            if(now_r >= a[i].second.first){
                int now_len = now_r - a[i].second.first + 1;
                max_len = max(max_len, now_len);
            } 
        }
    }
    if(max_len == 0){
        cout << 0 << endl;
        for(int i = 1; i <= k; i ++) cout << i << " ";
        cout << endl;
        return ;
    }

    while(q.size()) q.pop();

    for(int i = 1; i <= n; i ++){
        if((int)q.size() < k){
            q.push({a[i].second.second, a[i].first});
            vis[a[i].first] = 1;
        }
        else{
            if(a[i].second.second > q.top().first){
                vis[q.top().second] = 0;
                q.pop();
                q.push({a[i].second.second, a[i].first});  
                vis[a[i].first] = 1;            
            }
        }

        if((int)q.size() == k){
            int now_r = q.top().first;
            if(now_r >= a[i].second.first){
                int now_len = now_r - a[i].second.first + 1;
                if(now_len == max_len){
                    cout << max_len << endl;
                    for(int j = 1; j <= n; j ++){
                        if(vis[j]) cout << j << " ";
                    }
                    cout << endl;
                    return ;
                }
            } 
        }
    }
    return ;
}

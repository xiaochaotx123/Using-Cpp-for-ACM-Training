        adj[u].push_back(v);
        adj[v].push_back(u);
    }  
    root_dfs(1, -1);
    ans[1] = sum[1];
    ans_dfs(1, -1);
    for(int i = 1; i <= n; i ++) cout << ans[i] << " ";

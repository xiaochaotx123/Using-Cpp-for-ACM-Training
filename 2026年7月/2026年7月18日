void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    for(int i = 1; i <= n - 1; i ++){
        if(i == 1){
            a[i + 1] += a[i] - 1;
            a[i] = 1;
        }
        else{
            if(a[i] <= a[i - 1]){
                cout << "NO" << endl;
                return ;
            }
            a[i + 1] += a[i] - (a[i - 1] + 1);
            a[i] = a[i - 1] + 1;
        }
    }
    cout << (a[n] <= a[n - 1] ? "NO" : "YES") << endl;
    return ;
}

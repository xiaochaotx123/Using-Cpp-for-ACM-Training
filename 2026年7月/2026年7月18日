int n, m, q;

const int N = 300000 + 100;

// 将二维网格的位置转化为1维上面，方便操作
int get_pos(int x, int y){
    return (x - 1) * m + y;
}

int p[N];
int cnt[N], fish[N], min_way[N];

int find(int x){
    if(x != p[x]){
        int root = find(p[x]);
        min_way[x] = max(min_way[x], min_way[p[x]]);
        p[x] = root;
    }
    return p[x];
}

int dx[] = {0, 0, 1, -1};
int dy[] = {1, -1, 0, 0};

void solve(){
    
    cin >> n >> m >> q;
    for(int i = 1; i <= n; i ++){
        for(int j = 1; j <= m; j ++){
            int pos = get_pos(i, j);
            p[pos] = pos;
        }
    }

    int pre_ans = 0;
    while(q --){
        int op; cin >> op;
        if(op == 1){
            int x, y, v; cin >> x >> y >> v;
            x ^= pre_ans, y ^= pre_ans;
            int pos = get_pos(x, y);
            fish[pos] = v;
            cnt[pos] = 1;
            for(int i = 0; i < 4; i ++){
                int nx = x + dx[i], ny = y + dy[i];
                if(nx < 1 || nx > n || ny < 1 || ny > m) continue;
                int u = get_pos(x, y), v = get_pos(nx, ny);
                // 如果旁边v这个网格上鱼的大小为0，表示就是障碍，所以continue
                if(!fish[v]) continue; 
                int fu = find(u), fv = find(v);
                if(fu != fv){
                    min_way[fv] = fish[fu] - (cnt[fv] - 1);
                    cnt[fu] += cnt[fv];
                    p[fv] = fu;
                }
            }
            pre_ans = cnt[find(pos)] - 1;
            cout << pre_ans << endl;
        }
        else{
            int x, y; cin >> x >> y;
            x ^= pre_ans, y ^= pre_ans;
            int pos = get_pos(x, y);
            // 再次更新连通块中所有点的min_way是取该连通块中最大的那个 增加大小
            find(pos);
            pre_ans = max(0LL, min_way[pos] - fish[pos]);
            cout << pre_ans << endl;
        }
    }
    return ;
}

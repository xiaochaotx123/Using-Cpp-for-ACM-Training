const int N = 200000 + 100;

int n, a[N];
vector<int> adj[N];
int ans[N], sum[N];


void root_dfs(int u, int fa){
    if(a[u] == 1) sum[u] = 1;
    else sum[u] = -1;

    for(int v : adj[u]){
        if(v == fa) continue;
        root_dfs(v, u);
        sum[u] += max(0LL, sum[v]);
    }
}

void ans_dfs(int u, int fa){
    for(int v : adj[u]){
        if(v == fa) continue;
        ans[v] = max(0LL, ans[u] - max(0LL, sum[v])) + sum[v];
        ans_dfs(v, u);
    }
}

/*
https://codeforces.com/contest/1092/problem/F
知识点：换根dp思想
题意：给你n个节点的一棵树，定义节点v的贡献为 ∑(dist(i, v) * a[i])
  就是每一个节点到v的最短距离(节点i与节点v之间的最短边数) 乘以 节点i的权值, 求最大贡献
  如果使用LCA能够快速求出任意两个节点直接的最短距离，但是枚举起点以及枚举其他节点的总时间复杂度仍然为O(n ^ 2)
  但实际上，相邻节点之间的答案存在递推关系，不需要重新计算

过程：任意选择一个根(例如为1)，然后跑一边dfs，算出：
  sum[u]：以u为根的子树中，所有节点的权值之和
  ans[1]：以节点1为起点时的总贡献，即∑(dist(i, 1) * a[i])

  考虑这样一个性质：我从父节点p换到子节点c时，对于答案的变化：
  c子树内的所有节点，距离都减少了1  ==> 总代价减少了sum[c]
  c子树外的所有节点，距离都增加了1  ==> 总代价增加了total - sum[c] (total时所有节点的权值之和)

  然后进行第二遍dfs，更新所有节点的贡献
  最后取max
*/
const int N = 200000 + 100;
int n;
vector<int> adj[N];

int a[N], ans[N], sum[N], total;

void root_dfs(int u, int fa, int dep){
    ans[1] += a[u] * dep;
    sum[u] = a[u];
    for(int v : adj[u]){
        if(v == fa) continue;
        root_dfs(v, u, dep + 1);
        sum[u] += sum[v];
    }
}

void ans_dfs(int u, int fa){
    for(int v : adj[u]){
        if(v == fa) continue;
        ans[v] = ans[u] - sum[v] + (total - sum[v]);
        ans_dfs(v, u);
    }
}

void solve(){
    
    cin >> n;
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        total += a[i];
    }    
    for(int i = 1; i <= n - 1; i ++){
        int u, v; cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }
    root_dfs(1, -1, 0);
    ans_dfs(1, -1);
    int max_ans = ans[1];
    for(int i = 2; i <= n; i ++) max_ans = max(max_ans, ans[i]);
    cout << max_ans << endl;
    return ;
}

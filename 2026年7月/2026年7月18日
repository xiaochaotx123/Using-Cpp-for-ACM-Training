const int N = 200000 + 100;

int n;
vector<int> adj[N];
map<pair<int, int>, int> ma;

int ans[N];

void root_dfs(int u, int fa){
    for(int v : adj[u]){
        if(v == fa) continue;
        if(ma.count({u, v}) == 0) ans[1] ++;
        root_dfs(v, u);
    }
}

void ans_dfs(int u, int fa){
    for(int v : adj[u]){
        if(v == fa) continue;
        if(ma.count({u, v})) ans[v] = ans[u] + 1;
        else ans[v] = ans[u] - 1;
        ans_dfs(v, u);
    }
}
void solve(){
    
    cin >> n;
    for(int i = 1; i <= n - 1; i ++){
        int u, v; cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
        ma[{u, v}] = 1;
    }    
    root_dfs(1, -1);
    ans_dfs(1, -1);
    int min_ans = ans[1];
    for(int i = 2; i <= n; i ++) min_ans = min(min_ans, ans[i]);
    vector<int> fans;
    for(int i = 1; i <= n; i ++){
        if(ans[i] == min_ans) fans.push_back(i);
    }
    cout << min_ans << endl;
    for(int e : fans) cout << e << " ";
    cout << endl;
    return ;
}

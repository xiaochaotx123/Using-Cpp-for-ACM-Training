/*
https://codeforces.com/problemset/problem/543/D
知识点：换根dp思想 + 前缀后缀乘积
*/
const int N = 200000 + 100;
const int mod = 1000000000 + 7;

int n;
vector<int> adj[N];
int dp[N], ans[N];

void root_dfs(int u, int fa){
    dp[u] = 1;
    for(int v : adj[u]){
        if(v == fa) continue;
        root_dfs(v, u);
        dp[u] = (dp[u] * (1 + dp[v])) % mod; 
    }
} 

void ans_dfs(int u, int fa, int up){

    ans[u] = ((up + 1) * dp[u]) % mod;
    vector<int> son;
    for(int v : adj[u]){
        if(v == fa) continue;
        son.push_back(v); 
    }
    int m = (int)son.size();
    vector<int> pre(m + 10, 1), suf(m + 10, 1);
    for(int i = 1; i <= m; i ++){
        pre[i] = (pre[i - 1] * (dp[son[i - 1]] + 1)) % mod;
    }
    for(int i = m; i >= 1; i --){
        suf[i] = (suf[i + 1] * (dp[son[i - 1]] + 1)) % mod;
    }
    for(int i = 1; i <= m; i ++){
        int nex_up = (((pre[i - 1] * suf[i + 1]) % mod) * (up + 1)) % mod;
        ans_dfs(son[i - 1], u, nex_up);
    }
}

void solve(){

    cin >> n;
    for(int u = 2; u <= n; u ++){
        int v; cin >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }
    root_dfs(1, -1);
    ans_dfs(1, -1, 0);

    for(int i = 1; i <= n; i ++) cout << ans[i] << " ";
    cout << endl;
    return ;
}

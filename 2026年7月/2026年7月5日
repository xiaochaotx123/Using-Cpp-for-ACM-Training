    for(int v : adj[u]){
        if(!dfn[v]){
            Tarjan(v);
            low[u] = min(low[u], low[v]);
        }
        else if(in_stack[v]) low[u] = min(low[u], dfn[v]);
    }

    if(dfn[u] == low[u]){
        scc_cnt ++;
        int v = 0;
        while(v != u){
            v = sta.top();
            sta.pop();
            in_stack[v] = false;
            scc_id[v] = scc_cnt;
        }

void solve(){
    
    cin >> n;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    cin >> m;
    for(int i = 1; i <= m; i ++){
        int u, v; cin >> u >> v;
        adj[u].push_back(v);
    }

    for(int i = 1; i <= n; i ++){
        if(!dfn[i]) Tarjan(i);
    }

    vector<int> scc_mincost(scc_cnt + 10, inf), scc_mincost_cnt(scc_cnt + 10, 0);
    for(int i = 1; i <= n; i ++){
        int id = scc_id[i];
        if(scc_mincost[id] > a[i]){
            scc_mincost[id] = a[i];
            scc_mincost_cnt[id] = 1;
        }
        else if(scc_mincost[id] == a[i]){
            scc_mincost_cnt[id] ++;
        }
    }
    int total_cost = 0, total_cnt = 1;
    for(int i = 1; i <= scc_cnt; i ++){
        total_cost += scc_mincost[i];
        total_cnt = (total_cnt * scc_mincost_cnt[i]) % mod;
    }
    cout << total_cost << " " << total_cnt << endl;
    return ;
}

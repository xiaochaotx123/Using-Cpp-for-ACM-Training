const int N = 200000 + 100;
int n, m, h;
int t[N];
vector<int> adj[N];

int dfn[N], low[N];
int dfn_cnt;
stack<int> sta;
bool in_stack[N];

int scc_cnt;
int scc_id[N];
vector<int> dag[N];

map<pair<int, int>, int> ma;
void Tarjan(int u){
    dfn[u] = low[u] = ++ dfn_cnt;
    sta.push(u);
    in_stack[u] = true;

    for(int v : adj[u]){
        if(!dfn[v]){
            Tarjan(v);
            low[u] = min(low[u], low[v]);
        }
        else if(in_stack[v]) low[u] = min(low[u], dfn[v]);
    }

    if(dfn[u] == low[u]){
        scc_cnt ++;
        int v = 0;
        while(u != v){
            v = sta.top();
            sta.pop();
            in_stack[v] = false;
            scc_id[v] = scc_cnt;
        }
    }
}

void build_dag(){
    for(int u = 1; u <= n; u ++){
        for(int v : adj[u]){
            if(scc_id[u] != scc_id[v]) dag[scc_id[u]].push_back(scc_id[v]);
        }
    }
}

void solve(){
    
    cin >> n >> m >> h;
    for(int i = 1; i <= n; i ++) cin >> t[i];
    for(int i = 1; i <= m; i ++){
        int u, v; cin >> u >> v;
        int u1 = (t[u] + 1) % h, v1 = (t[v] + 1) % h;
        if(u1 == t[v] && ma.count({u, v}) == 0){
            ma[{u, v}] = 1;
            adj[u].push_back(v);
        }
        if(v1 == t[u] && ma.count({v, u}) == 0){
            ma[{v, u}] = 1;
            adj[v].push_back(u);
        }
    }

    for(int i = 1; i <= n; i ++){
        if(!dfn[i]) Tarjan(i);
    }


    build_dag();


    vector<int> num_scc_id(scc_cnt + 10);
    for(int i = 1; i <= n; i ++) num_scc_id[scc_id[i]] ++;
    int min_num = 1000000000, min_idx = 1;
    for(int i = 1; i <= scc_cnt; i ++){
        if(dag[i].size() == 0){
            // cout << "zero == " << i << endl;
            // cout << "here == " << num_scc_id[i] << " " << min_num << endl;
            if(num_scc_id[i] < min_num){
                min_num = num_scc_id[i];
                min_idx = i;
            }
        }
    }
    //cout << "min_idx " << min_idx << endl; 
    vector<int> ans;
    for(int i = 1; i <= n; i ++){
        //cout << "i == " << i << " " << "scc_id[i] == " << scc_id[i] << endl;
        if(scc_id[i] == min_idx) ans.push_back(i);
    }
    cout << (int)ans.size() << endl;
    for(int e : ans) cout << e << " ";
    cout << endl;

    return ;
}

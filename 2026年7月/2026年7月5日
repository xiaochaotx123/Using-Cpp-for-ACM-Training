const int N = 5000 + 100;
int n, m, root;

vector<int> adj[N];

int dfn[N], low[N];
int dfn_cnt, scc_cnt;

stack<int> sta;
bool in_stack[N];

int scc_id[N];
vector<int> dag[N];

int vis[N], indeg[N];
void dfs(int u){
    vis[u] = 1; 
    for(int v : dag[u]){
        if(vis[v]) continue;
        dfs(v);
    }
}

void Tarjan(int u){
    dfn[u] = low[u] = ++ dfn_cnt;
    sta.push(u);
    in_stack[u] = true;

    for(int v : adj[u]){
        if(!dfn[v]){
            Tarjan(v);
            low[u] = min(low[u], low[v]);
        }
        else if(in_stack[v]) low[u] = min(low[u], dfn[v]);
    }

    if(dfn[u] == low[u]){
        int v = 0;
        scc_cnt ++;
        while(u != v){
            v = sta.top();
            sta.pop();
            in_stack[v] = false;
            scc_id[v] = scc_cnt;
        }
    }
}

void build_dag(){
    for(int u = 1; u <= n; u ++){
        for(int v : adj[u]){
            if(scc_id[u] != scc_id[v]){
                indeg[scc_id[v]] ++;
                dag[scc_id[u]].push_back(scc_id[v]);
            }
        }
    }
}
void solve(){
    
    cin >> n >> m >> root;
    for(int i = 1; i <= m; i ++){
        int u, v; cin >> u >> v;
        adj[u].push_back(v);
    }

    for(int i = 1; i <= n; i ++){
        if(!dfn[i]) Tarjan(i);
    }

    build_dag();
    dfs(scc_id[root]);

    int ans = 0;
    for(int i = 1; i <= scc_cnt; i ++){
        if(vis[i]) continue;
        if(!indeg[i]) ans ++;
    }
    cout << ans << endl;
    return ;
}

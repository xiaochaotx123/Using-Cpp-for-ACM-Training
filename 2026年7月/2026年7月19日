/*
https://codeforces.com/contest/1905/problem/D
知识点：思维
题意：对于一个长度为n的数组a[]，现在可以对它向左循环移动，比如
    a[1], a[2], a[3], a[4], a[5]向左循环移动一位为 a[2], a[3], a[4], a[5], a[1]
    现在当前数组的贡献为mex(a[1]) + mex(a[1], a[2]) + ...mex(a[1], a[2], ... a[n - 1]) + mex(a[1], a[2], ..., a[n - 1], a[n])的和
    然后求所有循环数组中的最大的一个贡献为多少
解决：对于现在的数组a[1], a[2], a[3], a[4], a[5]来说，如果向左循环一次变为
    a[2], a[3], a[4], a[5], a[1].
    那么首先第一个mex(a[1])就消失了，对于其他原来的mex(a[1], a[2]), mex(a[1], a[2], a[3])....来说有：
    如果其原来的mex大于等于a[1], 那么就会变为a[1]
    如果其原来的mex小于a[1], 那么就会不变
    然后最后添加上一个新的mex = n
    对于上面的过程可以使用双端队列来模拟这个过程

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];

    首先定义deque<pair<int, int> > dq;
    需要将每一个位置的mex以及数量插入进入
    int mex = 0;
    vector<int> ma(n + 10);
    for(int i = 1; i <= n; i ++){
        ma[a[i]] ++;
        while(ma[mex]) mex ++;
        dq.push_back({mex, 1});
    }
    这样就将每个位置的前缀mex以及数量放入进去了
    然后将a[1]放入后面
    《因为dq放入的是前缀mex，所以是单调不递减的，我们只需要从后面往前面更新即可！》
    while(dq.size() && dq.back().first >= a[i]){
        sum -= dq.back().first * dq.back().second;
        dq.pop_back();
    }
    然后我还需要记录我现在a[1]的信息
    下面就是一部分代码：
    pair<int, int> me = {a[i], 0};
    sum -= dq.front().first;
    dq.front().second --;
    if(!dq.front().second) dq.pop_front();
    while(dq.size() && dq.back().first >= a[i]){
        sum -= dq.back().first * dq.back().second;
        me.second += dq.back().second;
        q.pop_back();
    }
    dq.push_back(me);
    sum += me.first * me.second;
    《最后需要插入一个mex = n，数量为1》
    dq.push_back({n, 1});
    sum += n;
    ans = max(ans, sum);
*/
void solve(){

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int ans = 0, sum = 0, mex = 0;
    deque<pair<int, int> > dq;
    vector<int> ma(n + 10);
    for(int i = 1; i <= n; i ++){
        ma[a[i]] ++;
        while(ma[mex]) mex ++;
        dq.push_back({mex, 1});
        sum += mex;
    }    
    ans = sum;

    for(int i = 1; i <= n - 1; i ++){
        pair<int, int> me = {a[i], 0};

        sum -= dq.front().first;
        dq.front().second --;
        if(!dq.front().second) dq.pop_front();

        while(dq.size() && dq.back().first >= a[i]){
            sum -= dq.back().first * dq.back().second;
            me.second += dq.back().second;
            dq.pop_back();
        }
        dq.push_back(me);
        sum += me.first * me.second;
        dq.push_back({n, 1});
        sum += n;
        ans = max(ans, sum);
    }

    cout << ans << endl;
    return ;
}

/*
https://codeforces.com/contest/1905/problem/C
题目的意思就是不断找字符串中字典序最大的一个子序列，然后进行一次循环右移操作
求最少操作多少次可以使得字符串升序操作，或者输出-1表示无法使得字符串升序

问题：如果快速求字典序最大的一个子序列？
    直接倒着处理：维护当前遇到的最大的字符，如果时大于等于就加进来
    vector<char> max_char;
    for(int i = n; i >= 1; i --){
        if(!max_char.size()) max_char.push_back(a[i]);
        else if(a[i] >= max_char.back()) max_char.push_back(a[i]);
    }
    所以：《一个字符串的字典序最大的一个子序列一定包含字符串的最后一个字符！》

现在求出了字典序最大的一个字符列后，进行一次循环右移
移动后变为s[n], s[1], s[2], ..., s[n - 1]
这时候字典序最大的一个子序列是s[1], s[2], s[3], ..., s[n - 1]
然后再次循环右移，那么为s[n - 1], s[1], s[2], s[3], ..., s[n - 2]
所以时间上到最后就只有一个s[1]
《然后整个字典序最大的子序列就相当于直接翻转了！》
一开始的s[1], s[2], ..., s[n]变为了s[n], s[n - 1], ..., s[2], s[1]!
所以现在只需要判断反转后，整个字符串是不是升序即可
如果不是，直接输出-1
否则求循环右移的次数，就是字典序最大的子序列的长度 - 1

然而wrong answer了，原因是比如最大子序列是 z z b a
那么需要循环右移的操作次数是3次吗，实际上只循环移动了2次变为a b z z
也就是说最后最大的那个字符不需要循环移动，直接就截至了，所以还得减去最大的字符个数 - 1
那么最终答案是 len - 1 - (cnt - 1) = len - cnt
len: 字典序最大的子序列的长度
cnt: 最大的字符的个数
*/
void solve(){

    int n; cin >> n;
    vector<char> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];

    vector<char> max_char;
    for(int i = n; i >= 1; i --){
        if(!max_char.size()) max_char.push_back(a[i]);
        else if(a[i] >= max_char.back()) max_char.push_back(a[i]);
    }
    reverse(max_char.begin(), max_char.end());

    vector<int> vis(n + 10);
    int idx = 0;
    for(int i = 1; i <= n; i ++){
        if(a[i] == max_char[idx]){
            vis[i] = 1;
            idx ++;
        }
    }

    int cnt = 0;
    for(int i = 0; i < max_char.size(); i ++){
        if(max_char[i] == max_char[0]) cnt ++;
        else break;
    }
    // for(char sh : max_char) cout << sh << " ";
    // cout << endl;

    idx = 0;
    reverse(max_char.begin(), max_char.end());
    
    for(int i = 1; i <= n; i ++){
        if(vis[i]) a[i] = max_char[idx ++];
    }
    
    for(int i = 1; i <= n - 1; i ++){
        if(a[i] > a[i + 1]){
            cout << "-1" << endl;
            return ;
        }
    }

    cout << (int)max_char.size() - cnt << endl;
    return ;
}

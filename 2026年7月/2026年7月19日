/*
https://atcoder.jp/contests/abc404/tasks/abc404_d
题目不难，但是对于dfs还是欠缺，这可是非常基础的dfs啊，啊，啊！
首先题目的数据范围非常小，非常适合使用dfs求解，一共只有n <= 10个动物园，直接dfs每一个动物园可以游览的次数0，1，2
不会大于等于3，因为题目说了至少两次即可，所以一个动物园最多只会浏览2次
*/
const int N = 20;
const int M = 120;

int n, m;
int ans = 1000000000000000000;
int a[N], cnt[N];
vector<int> adj[M];


void dfs(int step, int cost){
    if(step == n + 1){
        for(int i = 1; i <= m; i ++){
            int now_cnt = 0;
            for(int pos : adj[i]){
                now_cnt += cnt[pos];
            }
            if(now_cnt < 2) return;
        }
        ans = min(ans, cost);
        return ;
    }

    for(int i = 0; i <= 2; i ++){
        int nex_cost = cost + i * a[step];
        if(nex_cost >= ans) return ;
        cnt[step] = i;
        dfs(step + 1, nex_cost);
        cnt[step] = 0;
    }
}
void solve(){

    cin >> n >> m;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    for(int i = 1; i <= m; i ++){
        int k; cin >> k;
        for(int j = 1; j <= k; j ++){
            int pos; cin >> pos;
            adj[i].push_back(pos);
        }
    }    
    dfs(1, 0);
    cout << ans << endl;
    return ;
}

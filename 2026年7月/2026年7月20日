/*
https://codeforces.com/problemset/problem/1905/E
类似于线段树的一棵树，然后找所有叶子节点的非空子集的LCA的之和
例如当n = 3时
                [1, 3](1)
        [1, 2](2)          [3, 3](3)
    [1, 1](4)  [2, 2](5)
所以答案时{4}, {5}, {3}, {4, 5}, {3, 4}, {3, 5}, {3, 4, 5} = 4 + 5 + 3 + 2 + 1 + 1 + 1 = 17

没有思路，做不出来~
原因是所有叶子节点的非空子集很有是2的幂次方个，而对于每一个非空子集的LCA又不知道怎么求

第一点：正难则反，正面不好思考众多个非空子集对应的Lca，我们考虑对于每一个节点作为Lca的次数
    设该节点为u，他的左子树中有l个叶子节点，右子树中有r个叶子节点，那么节点u作为Lca的条件就是左子树中至少选取一个叶子节点并且右子树中之手选取一个叶子节点
    所以方案数就是(2^l - 1) × (2^r - 1)
    那么节点u对答案的贡献就是 u × (2^l - 1) × (2^r - 1)
所以如何求某个节点左子树有多少个叶子节点呢？
因为n最大为10的18次方，又该如何统计答案呢？

第二点：如果直接递归建树，遍历每一个节点的计算贡献，时间复杂度时O(n)，n最大为10的18次方，超时
    《线段树中，不同区间的长度的数量只有O(log(n))种。因为每次分裂，长度要么是(len + 1) / 2, 要么是len / 2
    所以，递归下去最多只有2log(n)不同的长度》

第三点：长度相同的区间只有编号不同，可以一起计算
    f[x] 表示长度为x的区间的编号的总和
    g[x] 表示长度为x的区间有多少个
    根节点长度为n，编号为1，所以长度为n的编号总和为1，且只有1个
    所以f[n] = g[n] = 1

    处理过程：使用大根堆从大到小处理长度
    《对于长度为x的节点，左右子区间的长度分别为 L = (x + 1) / 2, R = x / 2》
    计算所有长度为x的节点对答案的贡献：f[x] × (2^l - 1) × (2^R - 1)，因为是使用大根堆处理长度，所以当前的长度x一定是全部的长度了，后面不会继续产生长度为x的区间
    也就是说后面不会再产生长度为x的节点的贡献
    然后传递子节点
    因为左儿子编号 = 父节点编号 × 2
    所以f[L] += f[x] × 2
        g[L] += g[x]
    因为右儿子编号 = 父节点编号 × 2 + 1
    所以f[R] += f[x] × 2 + g[x] /每个右儿子比左儿子多1，所以多了g[x]个节点
        g[R] += g[x]
*/
const int mod = 998244353;

map<int, int> f, g, vis;

int n, ans;

void init(){
    f.clear();
    g.clear();
    vis.clear();
    ans = 0;
}

int ksm(int a, int b, int p){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a) % p;
        b >>= 1;
        a = (a * a) % p;
    }
    return sum;
}

void solve(){

    init();
    cin >> n;    

    priority_queue<int> q;
    f[n] = g[n] = vis[n] = 1;
    q.push(n);

    while(q.size()){
        int x = q.top();
        q.pop();

        if(x == 1) ans = (ans + f[x]) % mod;
        else{
            int L = (x + 1) / 2, R = x / 2;
            int sum = f[x];
            sum = (sum * (ksm(2, L, mod) - 1)) % mod;
            sum = (sum * (ksm(2, R, mod) - 1)) % mod;
            ans = (ans + sum) % mod;

            f[L] = (f[L] + 2 * f[x]) % mod;
            g[L] = (g[L] + g[x]) % mod;
            f[R] = (f[R] + 2 * f[x] + g[x]) % mod;
            g[R] = (g[R] + g[x]) % mod; 

            if(!vis[L]){
                vis[L] = 1;
                q.push(L);
            }
            if(!vis[R]){
                vis[R] = 1;
                q.push(R);
            }
        }
    }    
    cout << ans << endl;
    return ;
}

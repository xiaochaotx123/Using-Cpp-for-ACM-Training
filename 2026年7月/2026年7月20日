/*
https://atcoder.jp/contests/abc404/tasks/abc404_e
知识点：思维，贪心

分配豆子的贪心：
第一点：放豆子肯定是全部放入一个碗中，当然可以放入几个碗中，但是没有必要
第二点：如果放入豆子，选择放入已经有豆子的碗中和放入没有豆子的碗中优先选择已有豆子的碗中
    因为原来已经有豆子的碗本来就需要操作，这时候放入该碗中顺势而为
    如果选择没有豆子的碗中，需要新开一条路线经行操作
第三点：第二点是有豆子的碗就放入有豆子的碗中，如果全都没有豆子，那么需要贪心的去选择一个最优的空碗，就是
    选择[i - c[i], i - 1]中的j满足 j - c[j]最小的那个空碗！
*/
void solve(){

    int n; cin >> n;
    vector<int> c(n), a(n);
    for(int i = 1; i < n; i ++) cin >> c[i];
    for(int i = 1; i < n; i ++) cin >> a[i];
    
    int ans = 0;
    for(int i = n - 1; i >= 1; i --){
        if(!a[i]) continue;

        if(i - c[i] == 0){
            ans ++;
            continue;
        }
        int total_sum = 0;
        for(int j = i - c[i]; j <= i - 1; j ++) total_sum += a[j];
        if(total_sum){
            for(int j = i - c[i]; j <= i - 1; j ++){
                if(a[j]){
                    a[j] += a[i];
                    ans ++;
                    break;
                }
            }
        }
        else{
            int min_pos = (i - 1) - c[i - 1], now_pos = i - 1;
            for(int j = i - c[i]; j <= i - 1; j ++){
                if(min_pos > j - c[j]){
                    min_pos = j - c[j];
                    now_pos = j;
                }
            }
            a[now_pos] += a[i];
            ans ++;
        }
    }
    cout << ans << endl;
    return ;
}

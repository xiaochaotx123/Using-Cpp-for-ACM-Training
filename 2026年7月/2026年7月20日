/*
https://atcoder.jp/contests/abc405/tasks/abc405_f
将区间转化为点，如果区间a包含区间b，呢么a就是b的父亲节点

现在实线[a, b],虚线[c, d]，其实a，b一定都是偶数，c，d一定都是奇数
然后满足实现与虚线相交的条件是a < c < b < d或c < a < d < b
将区间转化为点后，设包含c点最小的区间是u，包含d点最小的区间是v，那么答案就是包含u且不包含v的区间个数 + 包含区间v但不包含区间u的区间个数
实际上，使用将区间转化为点，如果区间a包含区间b，呢么a就是b的父亲节点这样的方式建边后，答案就是dist[u] + dist[v] - dist[LCA(u, v)]

使用栈类似于括号匹配的方式建图：

stack<int> sta;
sta.push(0) /0是虚拟根

for(int i = 1; i <= 2 * n; i ++){
    if(!id[i]) continue;  /i 这个点不是区间的点的边界，所以直接跳过（相当于没有使用）
    
    if(i & 1){
        /是奇数，直接找包含该点的最小的区间，即 sta.top()
        min_cov[i] = sta.top();
    }
    else{
        /是偶数，现在就判断sta.top() 是不是等于 id[i]
        /如果等于，说明直接就是一个区间，然后将sta.top()删除，然后新的sta.top()就是包含该区间的最小区间
        /如果不等于，就将cur加入到栈中
        int cur = id[i];
        if(cur == sta.top()){
            sta.pop();
            int p = sta.top();
            adj[p].push_back(cur);
            adj[cur].push_back(p);
        }
        else sta.push(cur);
    }
}

剩下的就是LCA基操
*/
const int N = 2000000 + 100;
const int M = 25;
int n, m;

int id[N];
int min_cov[N], depth[N];
int st[N][M];
vector<int> adj[N];

void dfs(int u, int fa, int dep){
    depth[u] = dep;
    st[u][0] = fa;
    for(int v : adj[u]){
        if(v == fa) continue;
        dfs(v, u, dep + 1);
    }
}

int LCA(int u, int v){
    if(depth[u] < depth[v]) swap(u, v);
    int dif = depth[u] - depth[v];
    for(int i = M - 1; i >= 0; i --){
        if((dif >> i) & 1) u = st[u][i];
    }
    if(u == v) return u;

    for(int i = M - 1; i >= 0; i --){
        if(st[u][i] != st[v][i]){
            u = st[u][i];
            v = st[v][i];
        }
    }
    return st[u][0];
}

void solve(){

    cin >> n >> m;    
    for(int i = 1; i <= m; i ++){
        int a, b; cin >> a >> b;
        id[a] = id[b] = i;
    }
    stack<int> sta;
    sta.push(0);

    for(int i = 1; i <= 2 * n; i ++){
        if(i & 1) min_cov[i] = sta.top();
        else{
            if(!id[i]) continue;
            int cur = id[i];
            if(cur == sta.top()){
                sta.pop();
                int fa = sta.top();
                adj[cur].push_back(fa);
                adj[fa].push_back(cur);
            }
            else sta.push(cur);
        }
    }

    dfs(0, 0, 1);
    for(int j = 1; j < M; j ++){
        for(int i = 0; i <= m; i ++){
            st[i][j] = st[st[i][j - 1]][j - 1];
        }
    }

    int q; cin >> q;
    while(q --){
        int l, r; cin >> l >> r;
        int u = min_cov[l], v = min_cov[r];
        int p = LCA(u, v);
        cout << depth[u] + depth[v] - 2 * depth[p] << endl;
    }
    return ;
}

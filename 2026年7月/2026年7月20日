/*
求n的阶乘后面有多少个连续的0
n! 末尾的0来自于因子10，而10 = 2 × 5，在n! 的质因数分解中，质因子2的数量远多于质因子5，所以末尾0的个数就由因子5的个数决定
如果只用⌊n/5⌋来计算，会漏掉一些5。比如：
25 = 5 × 5，贡献了2个5，不能只算1个
125 = 5 × 5 × 5，贡献了3个5
《所以最终的贡献是ans = ⌊n/5⌋ + ⌊n/25⌋ + ⌊n/125⌋ + ....》
⌊n/5⌋：算5的倍数（每个治沙贡献1个5）
⌊n/25⌋：算25的倍数（每个额外多贡献1个5）
⌊n/125⌋：算125的倍数（每个再额外贡献1个5）
以此类推，知道5^k > n就停止
时间复杂度为log(5, n)
*/
//============================================================================================================================================
/*
https://codeforces.com/problemset/problem/633/B
*/
void solve(){

    vector<int> ans;
    int n; cin >> n;
    for(int i = 1; i <= 1000000; i ++){

        int x = i, cnt = 0;
        while(x){
            cnt += x / 5;
            x /= 5;
        }
        if(cnt == n) ans.push_back(i);
        else if(cnt > n) break;
    }
    cout << (int)ans.size() << endl;
    for(int x : ans) cout << x << " ";
    cout << endl; 
    return ;
}

/*
https://codeforces.com/problemset/problem/1114/C
给定n，求n! 转化为m进制数时末尾有多少个0

首先回想一下n!的阶乘对于10进制下有多少个末尾的0，因为对10质因数分解为2 × 5，然后找n!中有多少个2和有多少个5
因为2的个数比5多得多，所以只需要找5出现的次数，然后对于25，125等贡献多次，所以ans = ⌊n/5⌋ + ⌊n/25⌋ + ⌊n/125⌋ + ....

《对于末尾的0出现的本质就是该数字被能够被多少个该进制数整除》
所以只需要对b进行质因数分解即可，然后分别整除即可
比如现在b的一个质因子num出现了cnt次，然后在n不断的整除nun，得到now_cnt = ⌊n/num⌋ + ⌊n/(num × num)⌋ + ⌊n/(num × num × num)⌋ + ....
表示的是n!中质因子num出现的次数，那么将now_cnt / cnt就表示满足整除(num^cnt)的贡献
*/
int ksm(int a, int b){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a);
        b >>= 1;
        a = (a * a);
    }
    return sum;
}

void solve(){

    int n, b; cin >> n >> b;
    map<int, int> ma;
    for(int i = 2; i * i <= b; i ++){
        if(b % i == 0){
            while(b % i == 0){
                ma[i] ++;
                b /= i;
            }
        }
    }
    if(b != 1) ma[b] ++;

    int ans = 1000000000000000000;
    for(auto [num, cnt] : ma){
        //cout << num << " " << cnt << endl;
        int now_num = num;
        int now_ans = 0;
        int x = n;
        while(x){
            now_ans += x / now_num;
            x /= now_num;
        }
        ans = min(ans, now_ans / cnt);
    }
    cout << ans << endl;
    return ;
}

/*
https://atcoder.jp/contests/abc405/tasks/abc405_e?lang=en
挺考验数学推导能力的

给你A个苹果，B个橙子，C个香蕉，D葡萄
现在将这A + B + C + D个水果排成一行，要求：
每个苹果都放在每根香蕉的左边
每个苹果都放在每个葡萄的左边
每个桔子都放在每个葡萄的左边

说白了就是AC，AD，BD这样子

那么有下面这几种排列方式：
A B C D
A B D C
B A C D
B A D C
A C B D

关键点就是B这个水果可以放的位置，既可以放在前面和A组成一部分，也可以放在后面与C和D组成一部分
明锐的观察到：前面就是AB可以随便排列，那么排列的组合数为C(A + B, B)
后面BCD组成的排列方式为 B C D, C B D, B D C，因为B必须在D的左边，所以实际上只要C的位置确定了，那么B和D的位置就确定了
所以排列的组合数为C(B + C + D, C);

所以只需要枚举B的数量就可以了，因为可以一部分在AB中，一部分在BCD中

但是错了！
原因是重复了，虽然我定义的是前面有i个橘子和A混合排列，但是如果最后一个位置为橘子 与 后面BCD - i混合排列时第一个位置为橘子会重复！
比如(A)(B C D)和(A B)(B C D)重复了！
所以前面面C(A + B, B)修改为C(A + B - 1, B)表示最后一个位置放苹果，然后剩下的A + B - 1个位置随便选B个位置放橘子
*/
const int N = 4000000 + 100;
const int mod = 998244353;

int A, B, C, D;
int f[N];
int n;


int ksm(int a, int b, int p){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a) % p;
        b >>= 1;
        a = (a * a) % p;
    }
    return sum;
}
int get_C(int a, int b){
    int fz = f[a];
    int fm1 = ksm(f[b], mod - 2, mod);
    int fm2 = ksm(f[a - b], mod - 2, mod);
    int fm = (fm1 * fm2) % mod;
    int sum = (fz * fm) % mod;
    return sum;
}
void solve(){

    cin >> A >> B >> C >> D;
    int ans = 0;
    for(int i = 0; i <= B; i ++){
        int sum1 = get_C(A + i - 1, i);
        int sum2 = get_C(B + C + D - i, C);
        ans = (ans + (sum1 * sum2) % mod) % mod;
    }
    cout << ans << endl;
    return ;
}

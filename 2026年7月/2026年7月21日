/*
2026“钉耙编程”中国大学生算法设计暑期联赛（1）
Problem A. 小丑牌
*/
void solve(){

    int x, y, n, m; cin >> x >> y >> n >> m;
    
    vector<int> v1, v2;
    v1.push_back(0);
    v2.push_back(0);

    int mina = 10000000000, maxa = -10000000000;
    int minb = 10000000000, maxb = -10000000000;
    for(int i = 1; i <= n; i ++){
        int x; cin >> x;
        mina = min(mina, x);
        maxa = max(maxa, x);
    }
    for(int i = 1; i <= m; i ++){
        int x; cin >> x;
        minb = min(minb, x);
        maxb = max(maxb, x);
    }
    if(n){
        v1.push_back(mina);
        v1.push_back(maxa);
    }
    if(m){
        v2.push_back(minb);
        v2.push_back(maxb);
    }
    int ans = x * y;
    for(int i = 0; i < (int)v1.size(); i ++){
        for(int j = 0; j < (int)v2.size(); j ++){
            int sum = (x + v1[i]) * (y + v2[j]);
            ans = max(ans, sum);
        }
    }
    cout << ans << endl;

    return ;
}

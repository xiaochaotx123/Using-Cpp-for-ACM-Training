#include<bits/stdc++.h>
using namespace std;

#define endl '\n'
#define int long long
#define IOS ios::sync_with_stdio(false);cin.tie(NULL);cout.tie(NULL);
#define HelloWorld IOS;
const bool HAVE_CASE = false;


const int N = 20;
int n;

int a[N], vis[N];
int total_cnt[N];

void dfs(int x){
    if(x == n + 1){
        vector<int> ans(n + 10), cnt(n + 10);
        for(int i = 1; i <= n; i ++){
            cnt[a[i]] = 1;
            int now_cnt = 0;
            for(int j = 1; j <= n; j ++){
                if(j == 1){
                    if(cnt[j]) now_cnt ++;
                }
                if(cnt[j] == 0 && cnt[j + 1] == 1) now_cnt ++;
            }
            ans[a[i]] = now_cnt;
        }
        // cout << "----------" << endl;

        // for(int i = 1; i <= n; i ++) cout << a[i] << " ";
        // cout << endl;
        // for(int i = 1; i <= n; i ++) cout << ans[i] << " ";
        // cout << endl;
        // cout << "----------" << endl;

        for(int i = 1; i <= n; i ++) total_cnt[i] += ans[i];
        return ;
    }
    for(int i = 1; i <= n; i ++){
        if(vis[i]) continue;
        a[x] = i;
        vis[i] = 1;
        dfs(x + 1);
        vis[i] = 0;
    }
}

void solve(){

    cin >> n;
    dfs(1);
    for(int i = 1; i <= n; i ++) cout << total_cnt[i] << " ";
    cout << endl;
    return ;
}


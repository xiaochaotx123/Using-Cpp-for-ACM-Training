void solve(){

    int n; cin >> n;
    int l = 0, r = 100000, numa = 0;
    while(l <= r){
        int mid = (l + r) / 2;
        if(mid * (mid - 1) / 2 <= n){
            numa = mid;
            l = mid + 1;
        }
        else r = mid - 1;
    }

    cout << numa + n - numa * (numa - 1) / 2 << " " << 2 << endl;
    for(int i = 1; i <= numa; i ++) cout << 'a';
    for(int i = 1; i <= n - numa * (numa - 1) / 2; i ++) cout << 'b';
    cout << endl;
    return ;

const int N = 200000 + 100;
int n;
char a[N];

void solve(){

    cin >> n;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int ans = 0;
    for(int i = 1; i <= n; i ++){
        ans = (ans + i * (n - i + 1));
    }    
    vector<int> b;
    int sum = 0;
    b.push_back(sum);
    for(int i = 1; i <= n; i ++){
        if(a[i] == '0') sum --;
        else sum ++;
        b.push_back(sum);
    }
    sort(b.begin(), b.end());

    sum = 0;
    for(int i = 0; i < (int)b.size(); i ++) sum += b[i];
    for(int i = (int)b.size() - 1; i >= 0; i --){
        sum -= b[i];
        ans += i * b[i] - sum;
    }
    cout << ans / 2 << endl;
    return ;
}

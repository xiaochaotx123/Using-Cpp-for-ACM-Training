const int mod = 998244353;

int ksm(int a, int b, int p){
    int sum = 1;
    while(b){
        if(b & 1) sum = (sum * a) % p;
        b >>= 1;
        a = (a * a) % p;
    }
    return sum;
}

void solve(){

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];

    if(n == 1) cout << a[1] << endl;
    else if(n == 2){
        int ans = ((2 * a[1]) % mod + (2 * a[2]) % mod) % mod;
        ans = (ans * ksm(2, mod - 2, mod)) % mod;
        cout << ans << endl;
    }
    else if(n == 3){
        int ans = ((7 * a[1]) % mod + (6 * a[2]) % mod + (7 * a[3]) % mod) % mod;
        ans = (ans * ksm(6, mod - 2, mod)) % mod;
        cout << ans << endl;
    }
    else{
        int fm = 1;
        for(int i = 1; i <= n; i ++) fm = (fm * i) % mod;
        int x = 1, y = 7;
        for(int i = 4; i <= n; i ++){
            y = (y * i) % mod;
            x = (x * i) % mod;
            y = (y + x) % mod;
        }
        int x1 = (y - x + mod) % mod, x2 = y;
        int ans = ((a[1] * x2) % mod + (a[n] * x2) % mod) % mod;
        for(int i = 2; i <= n - 1; i ++){
            ans = (ans + (a[i] * x1) % mod) % mod;
        }
        ans = (ans * ksm(fm, mod - 2, mod)) % mod;
        cout << ans << endl;
    }
    return ;
}

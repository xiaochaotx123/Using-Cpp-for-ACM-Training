/*
2026“钉耙编程”中国大学生算法设计暑期联赛（1）
Problem J. 游戏
*/
void solve(){

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    if(n == 1) cout << "NO" << endl;
    else if(n == 2) cout << "YES" << endl;
    if(n <= 2) return ;

    int sum1 = 0, sum2 = 0, mid = n / 2 + 1;
    for(int i = 1; i < mid; i ++) sum1 += a[i];
    for(int i = mid + 1; i <= n; i ++) sum2 += a[i];
    if(sum1 > sum2) cout << "YES" << endl;
    else if(sum1 < sum2) cout << "NO" << endl;
    else{
        for(int i = 1; i < mid; i ++){
            sum1 -= a[mid - i];
            sum2 -= a[mid + i];
            if(sum1 != sum2){
                if(sum1 > sum2) cout << "YES" << endl;
                else cout << "NO" << endl;
                return ;
            }
        }
        if(n & 1) cout << "NO" << endl;
        else cout << "YES" << endl;
    }
    return ;
}

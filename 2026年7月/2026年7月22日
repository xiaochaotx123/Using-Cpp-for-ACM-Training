/*
2026牛客暑期多校训练营2
Problem B. 按位最大化

显然如果分为两个集合A, B，那么所有元素的异或和T = A ^ B
如果对于总异或和T中某一位上为1，那么A集合与B集合中在这一位上一定是一个为0一个为1，那么对最后的总贡献一定是有贡献的，所以不需要看为1的时候
如果T的某一位为0，那么在A和B中这一位要么同时为1要么同时为0，为了使得相加的结果更大，所以从高位到低位尽可能为1
在线性基中我们可以快速求出在数组中选取若干个数字的异或和的最大值，那么在这里需要求的是在数组中选取若干个数字对标total上为1的位置的异或最大值
所以我们insert()的时候不是直接insert(a[i])，而是insert(a[i] & total)这样对标一下
*/
const int M = 61;
int total, basis[M];


void insert(int x){
    for(int i = M - 1; i >= 0; i --){
        if(!((x >> i) & 1)) continue;
        if(!basis[i]){
            basis[i] = x;
            return ;
        }
        x ^= basis[i];
    }
}

int query_max(){
    int ans = 0;
    for(int i = M - 1; i >= 0; i --){
        if((ans ^ basis[i]) > ans) ans ^= basis[i];
    }
    return ans;
}

void solve(){
    total = 0;
    for(int i = 0; i < M; i ++) basis[i] = 0;    
    
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        total ^= a[i];
    }
    int mask = (~total) & ((1LL << M) - 1);
    
    for(int i = 1; i <= n; i ++) insert(mask & a[i]);
    int max_num = query_max();

    int ans = (int)(total ^ max_num) + max_num;
    cout << ans << endl;
    return ;
}

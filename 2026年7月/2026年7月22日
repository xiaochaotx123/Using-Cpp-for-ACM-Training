/*
2026牛客暑期多校训练营2
Problem N. 收拢至中位数
*/
void solve(){

    int n, m; cin >> n >> m;
    vector<int> a(n + 10), pre(n + 10);
    int ans = 0;
    for(int i = 1; i <= n; i ++){
        cin >> a[i];
        ans += a[i];
    }
    sort(a.begin() + 1, a.begin() + 1 + n);
    for(int i = 1; i <= n; i ++) pre[i] = pre[i - 1] + a[i];
    if(m & 1){
        int mid = (m + 1) / 2;
        int sum = pre[mid - 1];
        int change_num = -10000000000000000;
        for(int i = mid; i + mid - 1 <= n; i ++){
            int sum1 = pre[i + mid - 1] - pre[i];
            change_num = max(change_num, (m - 1) * a[i] - sum - sum1);
        }
        cout << ans + change_num << endl;
    }
    else{
        int mid = (m + 1) / 2;
        int sum = pre[mid - 1];
        int change_num = -10000000000000000;
        for(int i = mid; i + mid <= n; i ++){
            change_num = max(change_num, (a[i] + a[i + 1]) * (mid - 1) - (sum + pre[i + mid] - pre[i + 1]));
        }
        cout << ans + change_num << endl;
    }
    return ;
}

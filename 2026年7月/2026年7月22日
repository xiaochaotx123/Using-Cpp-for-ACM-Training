/*
https://codeforces.com/contest/2154/problem/C2
上面一道题目的困难版本，唯一不同在于代价b[i]的范围为[1, 1000000000]

显然思路是差不多的，但是有些地方需要仔细思考

如果一开始就存在两个数满足gcd大于1，直接输出0，return
for(int i = 1; i <= n; i ++){
    for(int v : adj[a[i].first]){
        if(vis[v]){
            cout << 0 << endl;
            return ;
        }
        vis[v] = 1;
    }
}    
int ans = 1000000000000

如果有一个偶数，那么此时可以将答案设置为奇数中最小的b[i]
如果全是奇数，那么此时答案为最小的两个b[i],b[j]

然后就可以输出答案了吗？实际上错了
原因是倒数第二组样例：
3
2 7 11
1 6 6
正确答案是5，但是输出了6
输出6是因为直接将7+1为偶数和可以和2的gcd大于1，但是一种更优的方法是将2不断的加到7，之间加了7-2=5次，代价是5×1=5
所以更小的代码时5而不是6

所以前面的思考中遗漏了一种情况：就是我可以将a数组中的某个数不断的加1，比如加了k次，那么如果a[i]+k可以与其他数的gcd大于1，那么此时的代价为k×b[i]
下面有两个问题：
我该选择哪一个a[i]来不断操作加1呢？
如果选择了a[i]，我该操作多少次呢？

对于第一个问题：
现在我们将b[i]从小到大排序（需要和a[]一一对应，所以使用pair）
比如现在的是
a[1], a[2], a[3], a[4], a[5]
b[1], b[2], b[3], b[4], b[5]
那么如果我对a[x](x >= 2)执行k次操作，代价为k×b[x]，是不如对a[1]和a[x]分别执行一次操作，代价为b[1]+b[x]
b[1]+b[x] <= k×b[x]，如果k=1，那么意思就是将a[x]执行一次操作，这在前面已经对每一个a[i]都执行过了
所以对a[x]操作都是没有直接对a[1]操作更优的
《也就是说如果要对a[i]多次操作，唯一也是最优的就是对a[1]操作》

对于第二个问题，现在已经知道只需要对a[1]操作，那么我要执行多少次才能使得使得gcd大于2
也就是a[1]+k对其他的所有a[i]存在gcd大于2，求这个最小的k，代价就是k×b[1]
巧妙的转化过来
例如对于a[x]，要想gcd(a[1]+k, a[x]) > 1，那么我们可以去枚举a[x]的质因子，然后经行类似于筛选的操作
将质因子不断的累加，直到第一个大于a[1]的值
比如现在a[1] = 15，a[x]的一个质因子为7，那么质因子7的倍数为7，14，21...
其中21是第一个大于15的数，所以停下累加，最小的操作次数就是21 - 15 = 6
就是遍历质因子的倍数，然后找到第一个大于a[1]的倍数，此时a[1]需要加上它们的差才能等于倍数，才能与质因子存在公因数
for(int i = 2; i <= n; i ++){
    for(int v : adj[a[i].first]){
        int min_len = 10000000000;
        for(int j = v; j < 4 * N; j += v){
            if(j >= a[1].first){
                min_len = j - a[1].first;
                break;
            }
        }
        ans = min(ans, min_len * a[1].second);
    }
}
*/
#include<bits/stdc++.h>
using namespace std;

#define endl '\n'
#define int long long
#define IOS ios::sync_with_stdio(false);cin.tie(NULL);cout.tie(NULL);
#define HelloWorld IOS;
const bool HAVE_CASE = true;

const int N = 200000 + 100;
vector<int> adj[N];

bool cmp(pair<int, int> a, pair<int, int> b){
    return a.second < b.second;
}

void solve(){

    int n; cin >> n;
    vector<pair<int, int> > a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i].first;
    for(int i = 1; i <= n; i ++) cin >> a[i].second;
    vector<int> vis(N + 10);

    for(int i = 1; i <= n; i ++){
        for(int v : adj[a[i].first]){
            if(vis[v]){
                cout << 0 << endl;
                return ;
            }
            vis[v] = 1;
        }
    }    
    int ans = 1000000000000;

    for(int i = 1; i <= n; i ++){
        for(int v : adj[a[i].first + 1]){
            if(vis[v]) ans = min(ans, a[i].second);
        }
    }
    sort(a.begin() + 1, a.begin() + 1 + n, cmp);
    int cnt = 0;
    for(int i = 1; i <= n; i ++){
        if(!(a[i].first & 1)) cnt ++;
    }
    if(cnt){
        for(int i = 1; i <= n; i ++){
            if(a[i].first & 1){
                ans = min(ans, a[i].second);
                break;
            }
        }
    }
    else ans = min(ans, a[1].second + a[2].second);

    for(int i = 2; i <= n; i ++){
        for(int v : adj[a[i].first]){
            int min_len = 10000000000;
            for(int j = v; j < 4 * N; j += v){
                if(j >= a[1].first){
                    // cout << j << " " << a[1].first << endl;
                    min_len = j - a[1].first;
                    break;
                }
            }
            ans = min(ans, min_len * a[1].second);
        }
    }
    cout << ans << endl;
    return ;
}

signed main(){
    HelloWorld;

    for(int i = 2; i < N; i ++){
        if(adj[i].size()) continue;
        for(int j = i; j < N; j += i){
            adj[j].push_back(i);
        }
    }

    int tt = 1; 
    if(HAVE_CASE) cin >> tt;
    while(tt --) solve();
    return 0;
}

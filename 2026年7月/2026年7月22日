#include<bits/stdc++.h>
using namespace std;

#define endl '\n'
#define int long long
#define IOS ios::sync_with_stdio(false);cin.tie(NULL);cout.tie(NULL);
#define HelloWorld IOS;
const bool HAVE_CASE = false;


const int M = 61;
int basis[M];

void insert(int x){
    for(int i = M - 1; i >= 0; i --){
        if(!((x >> i) & 1)) continue;
        if(!basis[i]){
            basis[i] = x;
            return ;
        }
        x ^= basis[i];
    }
}

int query_max(){
    int ans = 0;
    for(int i = M - 1; i >= 0; i --){
        if((ans ^ basis[i]) > ans) ans = ans ^ basis[i];
    }
    return ans;
}

void solve(){

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++){
        int x; cin >> x;
        insert(x);
    }
    cout << query_max() << endl;
    return ;
}

signed main(){
    HelloWorld;

    int tt = 1; 
    if(HAVE_CASE) cin >> tt;
    while(tt --) solve();
    return 0;
}

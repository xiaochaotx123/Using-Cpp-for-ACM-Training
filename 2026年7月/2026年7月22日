/*
https://codeforces.com/problemset/problem/520/B
*/
int n, m;

struct cmp{
    bool operator() (const pair<int, int> &a, const pair<int, int> &b)const{
        return a.second > b.second;
    }
};

void solve(){

    cin >> n >> m;
    vector<int> vis(100000);
    priority_queue<pair<int, int>, vector<pair<int, int>>, cmp> q;
    q.push({n, 0});
    vis[n] = 1;
    while(q.size()){
        auto now = q.top(); q.pop();
        int u = now.first, step = now.second;
        if(u == m){
            cout << step << endl;
            return ;
        }   
        int nex_num1 = u * 2;
        if(!vis[nex_num1] && nex_num1 <= 2 * m){
            vis[nex_num1] = 1;
            q.push({nex_num1, step + 1});
        }
        int nex_num2 = u - 1;
        if(!vis[nex_num2] && nex_num1 >= 1){
            vis[nex_num2] = 1;
            q.push({nex_num2, step + 1});
        }
    }
    return ;
}

const int mod = 1000000000 + 7;
const int N = 100000 + 100;

int n, k;
int vis[N];
vector<int> adj[N];

int p[N], cnt[N];

int find(int x){
    if(x != p[x]) p[x] = find(p[x]);
    return p[x];
}

void dfs(int u, int fa){

    int now_cnt = 0;

    for(int v : adj[u]){
        if(!vis[v]) now_cnt ++;
    }
    if(vis[u]) cnt[u] = now_cnt;

    for(int v : adj[u]){
        if(v == fa) continue;
        dfs(v, u);

        if(vis[u] && vis[v]){
            int fu = find(u), fv = find(v);
            if(fu != fv){
                // cout << "-----------" << endl;
                // cout << u << " " << fu << " " << cnt[fu] << endl;
                // cout << v << " " << fv << " " << cnt[fv] << endl;
                // cout << "-----------" << endl;

                cnt[fv] += cnt[fu];
                p[fu] = fv;
            }
        }

    }
}
void solve(){

    cin >> n >> k;
    for(int i = 1; i <= n; i ++){
        p[i] = i;
    }

    for(int i = 1; i <= k; i ++){
        int x; cin >> x;
        vis[x] = 1;
    }
    for(int i = 1; i <= n - 1; i ++){
        int u, v; cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    dfs(1, -1);

    int ans_cost = 0, ans_num = 1;

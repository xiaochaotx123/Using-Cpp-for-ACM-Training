        if(vis[i]){
            int fi = find(i);
            if(i == fi){
                // cout << i << " " << cnt[fi] << endl;
                ans_cost ++;
                ans_num = (ans_num * cnt[fi]);
            }
        }
    }
    cout << ans_cost << " " << ans_num << endl;
    return ;
}

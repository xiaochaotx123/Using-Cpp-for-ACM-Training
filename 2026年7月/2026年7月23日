/*
2026“钉耙编程”中国大学生算法设计暑期联赛（2）
最遥远的距离
*/
void solve(){

    int n; cin >> n;
    vector<vector<int> > adj(n + 10);

    int m = 0;
    for(int i = 1; i <= n; i ++){
        int x; cin >> x;
        adj[x].push_back(i);
        m = max(m, x);
    }
    
    vector<PII> ans;
    vector<int> b(n + 10), d(n + 10), db(n + 10);
    for(int i = 1; i <= m; i ++){
        b[i] = max(m - i + 1, i);
        if(adj[b[i]].size()){
            d[i] = adj[b[i]].back();
            adj[b[i]].pop_back();
        }
        else{
            cout << "No" << endl;
            return ;
        }
        db[b[i]] = d[i];
    }
    for(int i = 1; i < m; i ++) ans.push_back({d[i], d[i + 1]});
    for(int i = 1; i <= m; i ++){
        for(int v : adj[i]){
            if(!db[i - 1]){
                cout << "No" << endl;
                return ;
            }
            else ans.push_back({v, db[i - 1]});
        }
    }
    cout << "Yes" << endl;
    for(auto [x, y] : ans) cout << x << " " << y << endl;
    return ;
}

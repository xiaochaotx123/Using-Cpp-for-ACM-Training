/*
https://codeforces.com/gym/103643/problem/B
*/
void solve(){

    int a, b; cin >> a >> b;
    map<int, int> ma;
    int ans = 1;
    ma[a + b] = 1;
    if(ma.count(a * b) == 0){
        ans ++;
        ma[a * b] = 1;
    }
    if(ma.count(a - b) == 0){
        ans ++;
        ma[a - b] = 1;
    }
    if(ma.count(b - a) == 0){
        ans ++;
        ma[b - a] = 1;
    }
    if(a == b){
        if(ma.count(1) == 0){
            ans ++;
            ma[1] = 1;
        }
    }
    else{
        if(a % b == 0){
            if(ma.count(a / b) == 0){
                ans ++;
                ma[a / b] = 1;
            } 
        }
        else ans ++;

        if(b % a == 0){
            if(ma.count(b / a) == 0){
                ans ++;
                ma[b / a] = 1;
            } 
        }
        else ans ++;
    }

    cout << ans << endl;
    return ;
}

/*
https://codeforces.com/gym/103677/problem/L

题目数据n范围为(1 ≤ n ≤ 17)，数据范围不大，暗示我们可以使用状态压缩DP
使用状态压缩DP：定义dp[mask]表示：当前存活的葡萄干集合恰好为mask（mask的二进制位为1表示该葡萄干还活着）的概率
初始状态：dp[(1<<n) - 1] = 1.0（所有n颗葡萄干都活着）
状态转移：对于每个包含至少2颗葡萄干的状态mask（设其中有k颗），枚举其中的所有无序对（i，j）
1，选中这对的概率为 1 / C(k, 2)
2，i战胜j（概率p[i][j]）：状态转移到mask去掉j，即dp[mask ^ (1 << j)] += dp[mask] × (1 / C(k, 2)) × p[i][j];
3，j战胜i（概率p[i][j]）: 状态转移到mask去掉i，即dp[mask ^ (1 << i)] += dp[mask] × (1 / C(k, 2)) × p[j][i];

遍历顺序：从(1<<n)-1向0遍历，因为每次转移都是清除一个二进制位，新状态数值一定小于原状态，所以从大到小遍历可以保证每个状态在被处理时，所有能转移到它的状态都已经处理完毕
最终答案：对于第i颗葡萄干，答案就是dp[1<<i]（只剩它一颗的状态的概率）
*/
const int N = 20;
int n;
double dp[1LL << N];
double p[N][N];

void solve(){

    cin >> n;
    for(int i = 0; i < n; i ++){
        for(int j = 0; j < n; j ++) cin >> p[i][j];
    }    

    dp[(1LL << n) - 1] = 1.0;
    for(int mask = (1LL << n) - 1; mask >= 0; mask --){
        int now_mask = mask, cnt = 0;
        while(now_mask){
            if(now_mask & 1) cnt ++;
            now_mask /= 2;
        }
        if(cnt < 2) continue;

        double P = 2.0 / (cnt * (cnt - 1));
        for(int i = 0; i < n; i ++){
            if((mask >> i) & 1){
                for(int j = i + 1; j < n; j ++){
                    if((mask >> j) & 1){
                        dp[mask ^ (1LL << j)] += dp[mask] * P * p[i][j];
                        dp[mask ^ (1LL << i)] += dp[mask] * P * p[j][i];
                    }
                }
            }
        }
    }
    
    for(int i = 0; i < n; i ++) cout << dp[1 << i] << endl;
    return ;
}

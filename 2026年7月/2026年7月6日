bool cmp(pair<int, int> a, pair<int, int> b){
    return a.first < b.first;
}
void solve(){
    
    vector<pair<int, int> > a;
    int x, y; 
    while(cin >> x >> y){
        if(x > y) swap(x, y);
        a.push_back({x, y});
    }
    sort(a.begin(), a.end(), cmp);
    int max_r = 0, max_len = 0;
    for(int i = 0; i < (int)a.size(); i ++){
        if(i == 0) max_r = a[i].second;
        else{
            max_len = max(max_len, min(max_r, a[i].second) - a[i].first + 1);
            max_r = max(max_r, a[i].second);
        }
    }
    cout << max_len << endl;
    return ;
}

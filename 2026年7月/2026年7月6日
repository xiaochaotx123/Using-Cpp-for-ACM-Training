void solve(){
    
    int n; cin >> n;
    vector<int> a(n), b, v;
    for(int i = 0; i < n; i ++) cin >> a[i];
    map<int, int> ma;
    sort(a.begin(), a.end());
    b.push_back(a[n - 1]);
    for(int i = 0; i < n - 1; i ++){
        if(ma.count(a[i]) == 0){
            ma[a[i]] = 1;
            b.push_back(a[i]);
        }
        else v.push_back(a[i]);
    }
    for(int e : v) b.push_back(e);
    ma.clear();
    int mex_num = 0, ans = 0;
    for(int i = 0; i < n; i ++){
        ma[b[i]] = 1;
        while(ma[mex_num]) mex_num ++;
        ans += b[0] + mex_num;
    }
    cout << ans << endl;
    return ;
}

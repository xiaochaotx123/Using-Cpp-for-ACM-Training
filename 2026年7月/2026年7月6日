const int N = 200000 + 100;
int n, m; 
int p[N], q[N];

vector<int> adj[N];

int dfn[N], low[N];
int dfn_cnt, scc_cnt;

stack<int> sta;
bool in_stack[N];

int scc_id[N];

vector<int> dag[N];

int scc_indeg[N];

char sh = 'a';
int vis[N];

void Tarjan(int u){
    dfn[u] = low[u] = ++ dfn_cnt;
    sta.push(u);
    in_stack[u] = true;

    for(int v : adj[u]){
        if(!dfn[v]){
            Tarjan(v);
            low[u] = min(low[u], low[v]);
        }
        else if(in_stack[v]) low[u] = min(low[u], dfn[v]);
    }

    if(dfn[u] == low[u]){
        int v = 0;
        scc_cnt ++;
        while(u != v){
            v = sta.top();
            sta.pop();
            in_stack[v] = false;
            scc_id[v] = scc_cnt;
        }
    }
}


void build_dag(){
    for(int u = 1; u <= n; u ++){
        for(int v : adj[u]){
            if(scc_id[u] != scc_id[v]){
                scc_indeg[scc_id[v]] ++;
                dag[scc_id[u]].push_back(scc_id[v]);
            }
        }
    }
}

void dfs(int u, vector<char> &ans_char){
    if(!vis[u]){
        ans_char[u] = sh;
        if(sh < 'z') sh += 1;
    }
    vis[u] = 1;
    for(int v : dag[u]){
        if(vis[v]) continue;
        dfs(v, ans_char);
    }
}
void solve(){
    
    cin >> n >> m;
    for(int i = 1; i <= n; i ++) cin >> p[i];
    for(int i = 1; i <= n; i ++) cin >> q[i];
    
    for(int i = 1; i <= n - 1; i ++){
        adj[p[i]].push_back(p[i + 1]);
        adj[q[i]].push_back(q[i + 1]);
    }
    
    for(int i = 1; i <= n; i ++){
        if(!dfn[i]) Tarjan(i);
    }

    if(scc_cnt < m){
        cout << "NO" << endl;
        return ;
    }
    build_dag();

    vector<int> root;
    for(int i = 1; i <= scc_cnt; i ++){
        if(scc_indeg[i] == 0) root.push_back(i);
    }
    if(!root.size() || root.size() > 26){
        cout << "NO" << endl;
        return ;
    }

    vector<char> ans_char(scc_cnt + 10);
    for(int i = 0; i < (int)root.size(); i ++){
        vis[root[i]] = 1;
        ans_char[root[i]] = sh;
        sh += 1;
    }
    for(int i = 0; i < (int)root.size(); i ++) dfs(root[i], ans_char);
    
    cout << "YES" << endl;
    for(int i = 1; i <= n; i ++){
        cout << ans_char[scc_id[i]];
    }
    cout << endl;
    return ;
}

void solve(){
    
    int n; cin >> n;
    vector<pair<int, int> > a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i].first >> a[i].second;
    int ans = 0, pos = -1000000000000000000;
    for(int i = 1; i <= n; i ++){
        if(a[i].first - a[i].second > pos){
            ans ++;
            pos = a[i].first;
        }
        else if(i + 1 <= n && a[i].first + a[i].second < a[i + 1].first){
            ans ++;
            pos = a[i].first + a[i].second;
        }
        else if(i == n) ans ++;
        else pos = a[i].first;
    }
    cout << ans << endl;
    return ;
}

https://codeforces.com/gym/103306/problem/J

const int N = 2000000 + 100;
int n, final_time;
vector<pair<int, int> > adj[N + 10];


void solve(){
    cin >> n >> final_time;
    
    for(int i = 1; i <= n; i ++){
        int happy_score, duration_time, cnt_begintime;
        cin >> happy_score >> duration_time >> cnt_begintime;
        for(int j = 1; j <= cnt_begintime; j ++){
            int begintime; cin >> begintime;
            if(begintime <= final_time) adj[begintime + duration_time].push_back({begintime, happy_score});
        }
    }
    vector<int> ans(N + 10);
    for(int i = 1; i <= N; i ++){
        ans[i] = ans[i - 1];
        for(pair<int, int> &x : adj[i]){
            ans[i] = max(ans[i], ans[x.first] + x.second);
        }
    }
    int max_ans = 0;
    for(int i = 1; i <= N; i ++) max_ans = max(max_ans, ans[i]);
    cout << max_ans << endl;
    return ;    
}

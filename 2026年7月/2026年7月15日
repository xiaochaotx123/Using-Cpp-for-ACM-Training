https://codeforces.com/gym/103306/problem/D
void solve(){
    
    int a, b, c; cin >> a >> b >> c;
    // 求最多次数,那么直接就是 a / c
    // 遗漏了余数这种情况
    if(a % c == 0) cout << a / c << " ";
    else{
        int a1 = a, b1 = b;
        int cnt1 = a1 / c;
        a1 %= c;
        b1 %= c;
        if(b1 == 0) cout << cnt1 + 1 << " ";
        else{
            if(a1 + b1 <= c) cout << cnt1 << " ";
            else cout << cnt1 + 1 << " ";
        }
    }

    // 求最少次数,那么最优的方法是每一勺里面有1个葡萄糖,然后c-1个麦片,这样可以将麦片消耗的更多
    int total_cnt = (a + b + c - 1) / c;
    if(b >= total_cnt) cout << 0 << endl;
    else{
        a -= (c - 1) * b;
        cout << (a + c - 1) / c << endl;
    }
    return ;
}

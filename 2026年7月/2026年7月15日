https://codeforces.com/gym/103306/problem/E
const int N = 1000000 + 100;
int n, a[N], pre[N];
string storage;
int storage_num;
char storage_type;

bool check(int len){
    for(int i = 1; i <= n - len + 1; i ++){
        int l = i, r = i + len - 1;
        if(pre[r] - pre[l - 1] > storage_num) return false;
    }
    return true;
}

void solve(){
    cin >> n >> storage;
    storage_type = storage.back();
    for(int i = 0; i < (int)storage.size() - 1; i++){
        storage_num = storage_num * 10 + (storage[i] - '0');
    }
    if(storage_type == 'G') storage_num = storage_num * 1024;
    else if (storage_type == 'T') storage_num = storage_num * 1024 * 1024;
    for (int i = 1; i <= n; i++){
        cin >> a[i];
        pre[i] = pre[i - 1] + a[i];
    }
    int l = 1, r = n, max_len = 1;
    while (l <= r){
        int mid = (l + r) / 2;
        if (check(mid)){
            max_len = mid;
            l = mid + 1;
        }
        else r = mid - 1;
    }
    cout << max_len << " ";
    max_len += 1;
    for(int i = 1; i <= n - max_len + 1; i ++){
        int l = i, r = i + max_len - 1;
        if(pre[r] - pre[l - 1] > storage_num){
            cout << i << endl;
            return ;
        }
    }

    cout << "-1" << endl;
    return;
}

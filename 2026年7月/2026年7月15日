https://codeforces.com/gym/103306/problem/C
void solve(){
    
    string s; cin >> s;
    int n = (int)s.size();
    s = " " + s;
    vector<int> a(n + 10);
    int min_num = 0, pos = 0;
    for(int i = 1; i <= n; i ++){
        if(s[i] == 'B') a[i] = a[i - 1] + 1;
        else a[i] = a[i - 1] - 1;
        if(a[i] < min_num){
            pos = i;
            min_num = a[i];
        }
    }
    if(pos == n) cout << 0 << endl;
    else cout << pos << endl;
    return ;
}

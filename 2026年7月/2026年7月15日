https://codeforces.com/gym/103306/problem/G
const int N = 1000 + 100;
int n, m;

char a[N][N];
int ans[N][N];
int dx[] = {0, 0, 1, 1, 1, -1, -1, -1};
int dy[] = {1, -1, 1, 0, -1, 1, 0, -1};

void dfs(int x, int y){
    // 周围全部8个方向
    int max_len = 1;
    for(int i = 0; i < 8; i ++){
        int nx = x + dx[i], ny = y + dy[i];
        if(a[nx][ny] != a[x][y] + 1) continue;
        if(ans[nx][ny]){
            max_len = max(max_len, 1 + ans[nx][ny]);
            continue;
        }
        dfs(nx, ny);
        max_len = max(max_len, 1 + ans[nx][ny]);
    }
    ans[x][y] = max_len;
    return ;
}
void solve(){   
    
    cin >> n >> m;
    for(int i = 1; i <= n; i ++){
        for(int j = 1; j <= m; j ++) cin >> a[i][j];
    }
    for(int i = 1; i <= n; i ++){
        for(int j = 1; j <= m; j ++){
            dfs(i, j);
        }
    }

    int max_ans = 0;
    for(int i = 1; i <= n; i ++){
        for(int j = 1; j <= m; j ++) max_ans = max(max_ans, ans[i][j]);
    }
    cout << max_ans << endl;
    return ;
}

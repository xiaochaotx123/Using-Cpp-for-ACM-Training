https://codeforces.com/problemset/problem/1541/B
需要特别注意题目的条件说所有的数字不重复，直接将原本应该为O(n^2)的时间复杂度变为O(√n)
这个a[i] * a[j] = i + j条件没见过，所以一时间不知道怎么做
从1枚举到n，对于现在的枚举的i和已知a[i]，我需要判断是否存在j，满足j >= i 并且a[i] * a[j] = i + j
那么j = a[i] * a[j] - i，因为我不知道a[j]，所以就不知道j，就做不出来
但是如果携程a[j] = (i + j) / a[i]，显然a[j]是整数，所以(i + j)是a[i]的倍数，所以j = k * a[i] - i，直接枚举k即可！

void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10);
    int ans = 0;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    // a[j] = (i + j) / a[i], 所以j = k * a[j] - i;
    for(int i = 1; i <= n; i ++){
        // 我一直在想如果a[i]为1，那么内循环就会循环n次，那么总时间复杂度就是O(n^2)
        // 但因为每个数出现的次数最多为一次，所以内循环为 n/1 + n/2 + n/3 + n/4 + ... n/n = log(n)，所以总时间复杂度为O(n log(n))
        for(int k = 1; k * a[i] - i <= n; k ++){
            int j = k * a[i] - i;
            if(j <= i) continue;
            if(a[i] * a[j] == i + j) ans ++;
        }
    }
    cout << ans << endl;
    return ;
}

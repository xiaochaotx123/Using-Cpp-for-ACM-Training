nex[]数组的灵活使用
规定字符串下标从1开始，那么nex[i]表示从1到i这个字符串的子串中前缀子串等于后缀子串的最大成都
我们需要求这个字符串中的最大长度的子串满足既是前缀也是后缀也在中间出现过
那么我们枚举所有的位置pos在[2, n - 1]，那么nex[pos]表示从[1, pos]这个区间中最大长度前缀等于后缀
那么我们现在相当于得到了前缀和中间出现的部分，那么我们再判断后缀是否存在即可，使用哈希表快速判断即可
#define ull unsigned long long 
const int N = 1000000 + 100;
const ull base = 131;
ull h[N], p[N];

string s;
int n, nex[N];

ull get_hash(int l, int r){
    return h[r] - h[l - 1] * p[r - l + 1];
}
void get_nex(){
    nex[0] = -1;
    int j = -1;
    for(int i = 1; i <= n; i ++){
        while(j != -1 && s[i] != s[j + 1]) j = nex[j];
        j ++;
        nex[i] = j;
    }
}

void solve(){
    
    p[0] = 1;
    for(int i = 1; i < N; i ++) p[i] = p[i - 1] * base;
    cin >> s;
    n = (int)s.size();
    s = " " + s;
    get_nex();
    
    for(int i = 1; i <= n; i ++) h[i] = h[i - 1] * base + (s[i] - 'a');

    int ans = 0;
    for(int i = 2; i <= n - 1; i ++){
        if(nex[i] >= 1){
            ull sum1 = get_hash(1, nex[i]);
            ull sum2 = get_hash(n - nex[i] + 1, n);
            if(sum1 == sum2) ans = max(ans, nex[i]);
        }
    }
    if(ans){
        for(int i = 1; i <= ans; i ++) cout << s[i];
        cout << endl;
    }
    else cout << "Just a legend" << endl;
    return ;
}

https://codeforces.com/problemset/problem/1925/B
显然如果最大公因数为g，那么
设a[1] = a1 * g, a[2] = a2 * g, ...., a[m] = am * g;
那么(a1 + a2 + a3 + ... + am) * g = n;
所以我直接暴力枚举n的因子即可，时间复杂度为√n
当 n % i == 0时，i * (n / i) = n，那么只需要满足：
如果 i >= m，那么n / i就可以成为最大公因数
如果 n / i >= m， 那么i就可以成为最大公因数

void solve(){
    
    int n, m; cin >> n >> m;
    int ans = 1;
    for(int i = 1; i * i <= n; i ++){
        if(!(n % i)){
            if((n / i) >= m) ans = max(ans, i);
            if(i >= m) ans = max(ans, n / i);
        }
    }
    cout << ans << endl;
    return ;
}

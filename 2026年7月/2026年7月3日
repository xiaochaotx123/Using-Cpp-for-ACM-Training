https://www.matiji.net/exam/brushquestion/1/800/7F280BDFD141C1E2D42F7D8906B2F5B9?from=1

我的做法是直接枚举所有的起点从1到n/2，如果起点大于了n/2，那么即使最少的两个数也会大于n，所以有边界只需要枚举到n/2
然后二分去找长度，因为这个使用公式计算（起点为a，长度为d的和为 (a + a + d - 1) * d / 2）满足单调性
这样做的时间复杂度是O(n log n)
int n;

bool check(int start, int len){
    int sum = (start + start + len - 1) * len / 2;
    if(sum >= n) return true;
    else return false;
}
void solve(){
    
    bool ok = false;
    cin >> n;
    for(int i = 1; i <= n / 2; i ++){
        int l = 2, r = n + 10, len = -1;
        while(l <= r){
            int mid = (l + r) / 2;
            if(check(i, mid)){
                len = mid;
                r = mid - 1;
            }
            else l = mid + 1;
        }
        if(len != -1){
            int sum = (i + i + len - 1) * len / 2;
            if(sum == n){
                ok = true;
                for(int j = i; j <= i + len - 1; j ++) cout << j << " ";
                cout << endl;
            }
        }
    }
    if(!ok) cout << "NONE" << endl;
    return ;
}

优化版本：使用数学公式推导将时间复杂度降低为 O(√n)
起点为a，长度为k的和为(a + a + k - 1) * k / 2，这个值要等于 n，所以 (a + a + k - 1) * k = 2 * n
设m = (a + a + k - 1)，那么m * k = 2 * n，可以得到两个信息：
1：m > k
2：m和k的奇偶性不同
我们枚举d，d为长度，至少为2；因为m * k = 2 * n，所以k最大不会超过√(2n)

int n;
void solve(){
    
    cin >> n;
    vector<pair<int, int> > ans;
    for(int k = 2; k <= (int)(sqrt(2 * n)); k ++){ // 枚举k
        if((2 * n) % k == 0){ // 首先满足k整除2n
            int m = 2 * n / k;
            if(m > k && ((m - k) & 1)){ // 对于m需要满足m大于k并且m和k的奇偶性不同
                int a = (m - (k - 1)) / 2;
                ans.push_back({a, k});
            }
        }
    }
    sort(ans.begin(), ans.end());
    if(ans.size()){
        for(auto [a, k] : ans){
            for(int i = a; i <= a + k - 1; i ++) cout << i << " ";
            cout << endl;
        }
    }
    else cout << "NONE" << endl;
    return ;
}

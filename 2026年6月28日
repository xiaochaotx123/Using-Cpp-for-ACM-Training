const int N = 100 + 100;

int n, a[N], ans[N];

void dfs(int l, int r, int depth){
    int root = 0, root_idx;
    for(int i = l; i <= r; i ++){
        if(a[i] > root){
            root = a[i];
            root_idx = i;
        }
    }
    ans[root] = depth;
    if(root_idx > l) dfs(l, root_idx - 1, depth + 1);
    if(root_idx < r) dfs(root_idx + 1, r, depth + 1);
}
void solve(){
    
    cin >> n;
    for(int i = 1; i <= n; i ++) cin >> a[i];
    dfs(1, n, 0);    
    for(int i = 1; i <= n; i ++) cout << ans[a[i]] << " ";
    cout << endl;
    return ;
}

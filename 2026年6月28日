bool work(int x){
    int l = 1, r = 10000, pos= 1;
    while(l <= r){
        int mid = (l + r) / 2;
        if(mid * mid * mid <= x){
            pos = mid;
            l = mid + 1;
        }
        else r = mid - 1;
    }
    if(pos * pos * pos == x) return true;
    else return false;
}
void solve(){
    
    int n; cin >> n;
    for(int i = 1; i <= 10000; i ++){
        if(i * i * i >= n) break;
        int m = n - i * i * i;
        if(work(m)){
            cout << "YES" << endl;
            return ;
        }
    }
    cout << "NO" << endl;
    return ;
}

void solve(){
    
    int n; cin >> n;
    vector<int> a(n + 10), b(n + 10), pre(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i], b[i] = a[i];
    sort(b.begin() + 1, b.begin() + 1 + n);
    int min_num = b[n];
    for(int i = 1; i <= n; i ++) pre[i] = pre[i - 1] + b[i];

    for(int i = n - 1; i >= 1; i --){
        if(pre[i] >= b[i + 1]) min_num = b[i];
        else break;
    }
    vector<int> ans;
    for(int i = 1; i <= n; i ++){
        if(a[i] >= min_num) ans.push_back(i);
    }
    cout << (int)ans.size() << endl;
    for(int e : ans) cout << e << " ";
    cout << endl;
    
    return ;
}

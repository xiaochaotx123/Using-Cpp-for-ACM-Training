const int mod = 1000000000 + 7;

int gcd(int a, int b){
    if(!b) return a;
    else return gcd(b, a % b);
}
int lcm(int a, int b){  
    return a / gcd(a, b) * b;
}

void solve(){
    
    int n; cin >> n;
    int ans = 0, now_lcm = 1;
    for(int i = 2; ; i ++){
        if(now_lcm > n) break;
        int next_lcm = lcm(now_lcm, i);
        int sum = n / now_lcm - n / next_lcm;
        sum = (sum * i) % mod;
        ans = (ans + sum) % mod;
        now_lcm = next_lcm;
    }
    cout << ans << endl;
    return ;
}

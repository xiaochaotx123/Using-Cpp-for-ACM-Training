void solve(){

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int ans = 0;
    for(int i = 1; i <= n; i ++){
        if(i & 1) ans += a[i];
    }

    int max_sum = 0, now_sum = 0;

    for(int i = 2; i <= n; i += 2){
        now_sum += a[i] - a[i - 1];
        max_sum = max(max_sum, now_sum);
        if(now_sum < 0) now_sum = 0; 
    }
    now_sum = 0;
    for(int i = 3; i <= n; i += 2){
        now_sum -= a[i] - a[i - 1];
        max_sum = max(max_sum, now_sum);
        if(now_sum < 0) now_sum = 0;
    }
    cout << ans + max_sum << endl;
    return ;
}

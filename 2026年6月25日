bool cmp(int a, int b){
    return a > b;
}

void solve(){
        
    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    sort(a.begin() + 1, a.begin() + 1 + n, cmp);
    for(int i = 3; i <= n; i ++){
        if((a[i - 2] % a[i - 1]) != a[i]){
            cout << "-1" << endl;
            return ;
        }
    }
    cout << a[1] << " " << a[2] << endl;
    return ;
}

    int n; cin >> n;
    vector<int> a(n + 10);
    for(int i = 1; i <= n; i ++) cin >> a[i];
    int ans = 0;
    for(int i = 2; i <= n; i ++){
        if(a[i] >= a[i - 1] * 2){
            int x = a[i - 1];
            while(x * 2 < a[i]){
                x *= 2;
                ans ++;
            }
        }
    }
    for(int i = n - 1; i >= 1; i --){
        if(a[i] >= a[i + 1] * 2){
            int x = a[i + 1];
            while(x * 2 < a[i]){
                ans ++;
                x *= 2;
            }
        }
    }
    cout << ans << endl;
    return ;
}

const int N = 200000 + 1000;

int n, ans;
vector<int> adj[N];
int cnt[N], cnt_odd[N], cnt_even[N], vis[N];

void dfs_getnodes(int u, int fa){
    if(adj[u].size() == 1 && adj[u][0] == fa){
        cnt[u] = 1;
        vis[u] = 1;
        ans ++;
        return ;
    }
    else{
        for(int v : adj[u]){
            if(v == fa) continue;
            dfs_getnodes(v, u);
            cnt[u] += cnt[v];
        }
        if(cnt[u] & 1) ans ++;
    }
}

void dfs_getcnt(int u, int fa, int cntodd, int cnteven){
    cnt_odd[u] = cntodd + (cnt[u] & 1);
    cnt_even[u] = cnteven + (!(cnt[u] & 1));
    for(int v : adj[u]){
        if(v == fa) continue;
        if(cnt[u] & 1){
            cntodd ++;
            dfs_getcnt(v, u, cntodd, cnteven);
            cntodd --;
        }
        else{
            cnteven ++;
            dfs_getcnt(v, u, cntodd, cnteven);
            cnteven --;
        }
    }
}
void solve(){
    
    cin >> n;
    ans = 0;
    for(int i = 1; i <= n; i ++){
        adj[i].clear();
        cnt[i] = cnt_odd[i] = cnt_even[i] = vis[i] = 0;
    }
    for(int i = 1; i <= n - 1; i ++){
        int u, v; cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }
    if(adj[1].size() == 1) cnt[1] = 1, vis[1] = 1;
    dfs_getnodes(1, -1);
    dfs_getcnt(1, -1, 0, 0);
    //for(int i = 1; i <= n; i ++) cout << i << " " << cnt[i] << endl;
    int total_cnt = 0;
    for(int i = 1; i <= n; i ++){
        if(vis[i]) total_cnt ++;
    }
    if(total_cnt & 1){
        int fans = 1000000000000000000;
        for(int i = 1; i <= n; i ++){
            if(vis[i]){
                fans = min(fans, ans - cnt_odd[i] + cnt_even[i]);
            }
        }
        cout << fans << endl;
    }
    else cout << ans << endl;
    return ;
}
